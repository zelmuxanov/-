@model CarRental.Web.ViewModels.Admin.AdminUserDetailsViewModel
@using CarRental.Domain.Enums
@{
    ViewData["Title"] = "Детали пользователя";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Назад к списку
    </a>
</div>

<!-- Сообщения -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <!-- Основная информация -->
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Основная информация</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">ID:</dt>
                    <dd class="col-sm-8"><small class="text-muted">@Model.User.Id</small></dd>
                    
                    <dt class="col-sm-4">Имя:</dt>
                    <dd class="col-sm-8">@Model.User.FirstName @Model.User.LastName @Model.User.MiddleName</dd>
                    
                    <dt class="col-sm-4">Email:</dt>
                    <dd class="col-sm-8">@Model.User.Email</dd>
                    
                    <dt class="col-sm-4">Телефон:</dt>
                    <dd class="col-sm-8">@Model.User.PhoneNumber</dd>
                    
                    <dt class="col-sm-4">Дата рождения:</dt>
                    <dd class="col-sm-8">@Model.User.BirthDate.ToString("dd.MM.yyyy")</dd>
                    
                    <dt class="col-sm-4">Стаж вождения:</dt>
                    <dd class="col-sm-8">@Model.User.DrivingExperience лет</dd>
                    
                    <dt class="col-sm-4">Статус:</dt>
                    <dd class="col-sm-8">
                        @switch (Model.User.Status)
                        {
                            case UserStatus.Pending:
                                <span class="badge bg-warning">На рассмотрении</span>
                                break;
                            case UserStatus.Active:
                                <span class="badge bg-success">Активен</span>
                                break;
                            case UserStatus.Blocked:
                                <span class="badge bg-danger">Заблокирован</span>
                                break;
                            case UserStatus.Rejected:
                                <span class="badge bg-secondary">Отклонен</span>
                                break;
                        }
                    </dd>
                    
                    <dt class="col-sm-4">Дата регистрации:</dt>
                    <dd class="col-sm-8">@Model.User.RegistrationDate.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
                
                <div class="mt-4">
                    @if (Model.User.Status == UserStatus.Pending)
                    {
                        <form method="post" action="@Url.Action("Activate", new { id = Model.User.Id })" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success" 
                                    onclick="return confirm('Активировать пользователя @Model.User.Email?')">
                                <i class="fas fa-check me-2"></i>Активировать
                            </button>
                        </form>
                    }
                    
                    @if (Model.User.Status == UserStatus.Active)
                    {
                        <form method="post" action="@Url.Action("Block", new { id = Model.User.Id })" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-warning" 
                                    onclick="return confirm('Заблокировать пользователя @Model.User.Email?')">
                                <i class="fas fa-ban me-2"></i>Заблокировать
                            </button>
                        </form>
                    }
                    
                    @if (Model.User.Status == UserStatus.Blocked)
                    {
                        <form method="post" action="@Url.Action("Unblock", new { id = Model.User.Id })" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success" 
                                    onclick="return confirm('Разблокировать пользователя @Model.User.Email?')">
                                <i class="fas fa-unlock me-2"></i>Разблокировать
                            </button>
                        </form>
                    }
                    
                    @if (ViewBag.UserChatId != null)
                    {
                        <a asp-area="Admin" asp-controller="Chat" asp-action="Index" asp-route-chatId="@ViewBag.UserChatId" class="btn btn-primary">
                            <i class="fas fa-comments"></i> Открыть чат с пользователем
                        </a>
                    }
                    else
                    {
                        <form asp-area="Admin" asp-controller="Chat" asp-action="CreateChatForUser" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@Model.User.Id" />
                            <button type="submit" class="btn btn-outline-primary">
                                <i class="fas fa-plus"></i> Начать чат
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <!-- Документы (обновлённый блок) -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Документы</h5>
                <a asp-area="Admin" asp-controller="Documents" asp-action="Index" asp-route-userId="@Model.User.Id">
                    Все документы пользователя
                </a>
            </div>
            <div class="card-body">
                @if (Model.Documents != null && Model.Documents.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var doc in Model.Documents.OrderByDescending(d => d.CreatedAt))
                        {
                            <div class="list-group-item px-0">
                                <div class="d-flex w-100 justify-content-between">
                                    <div>
                                        <h6 class="mb-1">@GetDocumentTypeName(doc.DocumentType)</h6>
                                        <p class="mb-1 small">
                                            @if (!string.IsNullOrEmpty(doc.DocumentNumber))
                                            {
                                                <span>Номер: @doc.DocumentNumber</span>
                                            }
                                            @if (doc.Status == "Verified")
                                            {
                                                <span class="badge bg-success ms-2">Подтверждён</span>
                                            }
                                            else if (doc.Status == "Rejected")
                                            {
                                                <span class="badge bg-danger ms-2">Отклонён</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning ms-2">На проверке</span>
                                            }
                                        </p>
                                        @if (!string.IsNullOrEmpty(doc.Description) && doc.Status == "Rejected")
                                        {
                                            <small class="text-danger">@doc.Description</small>
                                        }
                                    </div>
                                    <div>
                                        <a href="@Url.Action("Details", "Documents", new { area = "Admin", id = doc.Id })" class="btn btn-sm btn-outline-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">Документы не загружены.</p>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    string GetDocumentTypeName(CarRental.Domain.Enums.DocumentType type)
    {
        return type switch
        {
            CarRental.Domain.Enums.DocumentType.Passport => "Паспорт",
            CarRental.Domain.Enums.DocumentType.DriverLicense => "Водительское удостоверение",
            CarRental.Domain.Enums.DocumentType.IdentityCard => "Удостоверение личности",
            CarRental.Domain.Enums.DocumentType.Insurance => "Страховка",
            _ => "Документ"
        };
    }
}