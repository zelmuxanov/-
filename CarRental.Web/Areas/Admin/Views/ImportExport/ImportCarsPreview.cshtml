@model CarRental.Web.Areas.Admin.Controllers.ImportExportController.ImportCarsViewModel
@{
    ViewData["Title"] = "Предпросмотр импорта";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
<h2>Редактирование данных перед сохранением</h2>
<form asp-action="SaveImportedCars" method="post">
    @Html.AntiForgeryToken()
    <div class="table-responsive">
        <table class="table table-bordered table-sm">
            <thead>
                <tr>
                    <th>Бренд</th><th>Модель</th><th>Год</th><th>Цвет</th><th>Цена/сут</th>
                    <th>Класс</th><th>КПП</th><th>Топливо</th><th>Мест</th><th>Объём</th>
                    <th>Госномер</th><th>VIN</th><th>Описание</th><th>Доступен</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Rows.Count; i++)
                {
                    <tr>
                        <td><input asp-for="Rows[i].Brand" class="form-control form-control-sm" /></td>
                        <td><input asp-for="Rows[i].Model" class="form-control form-control-sm" /></td>
                        <td><input asp-for="Rows[i].Year" class="form-control form-control-sm" type="number" /></td>
                        <td><input asp-for="Rows[i].Color" class="form-control form-control-sm" /></td>
                        <td><input asp-for="Rows[i].PricePerDay" class="form-control form-control-sm" type="number" step="0.01" /></td>
                        <td><input asp-for="Rows[i].Class" class="form-control form-control-sm" /></td>
                        <td><input asp-for="Rows[i].Transmission" class="form-control form-control-sm" /></td>
                        <td><input asp-for="Rows[i].FuelType" class="form-control form-control-sm" /></td>
                        <td><input asp-for="Rows[i].Seats" class="form-control form-control-sm" type="number" /></td>
                        <td><input asp-for="Rows[i].EngineCapacity" class="form-control form-control-sm" type="number" step="0.1" /></td>
                        <td><input asp-for="Rows[i].LicensePlate" class="form-control form-control-sm" /></td>
                        <td><input asp-for="Rows[i].VIN" class="form-control form-control-sm" /></td>
                        <td><input asp-for="Rows[i].Description" class="form-control form-control-sm" /></td>
                        <td>
                            <input type="hidden" asp-for="Rows[i].IsAvailable" value="false" />
                            <input asp-for="Rows[i].IsAvailable" type="checkbox" checked="@Model.Rows[i].IsAvailable" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <button type="submit" class="btn btn-success">Сохранить все автомобили</button>
    <a asp-action="ImportCars" class="btn btn-secondary">Отменить</a>
</form>