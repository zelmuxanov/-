@model CarRental.Web.Areas.Admin.Controllers.ImportExportController.ImportCarsViewModel
@{
    ViewData["Title"] = "Импорт автомобилей из Excel";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
<h2>@ViewData["Title"]</h2>
<div class="card">
    <div class="card-body">
        <form asp-action="ImportCars" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Выберите Excel-файл (.xlsx)</label>
                <input type="file" name="file" class="form-control" accept=".xlsx" required />
            </div>
            <button type="submit" class="btn btn-primary">Загрузить и просмотреть</button>
        </form>
    </div>
</div>