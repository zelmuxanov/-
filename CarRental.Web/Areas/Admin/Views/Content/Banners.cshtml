@model CarRental.Web.ViewModels.Admin.BannerIndexViewModel
@using CarRental.Domain.Enums

@{
    ViewData["Title"] = "Управление баннерами";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">
        <i class="fas fa-images me-2"></i>@ViewData["Title"]
    </h1>
    <div>
        <a asp-area="Admin" asp-controller="Content" asp-action="Index" class="btn btn-outline-secondary me-2">
            <i class="fas fa-arrow-left me-1"></i>Назад
        </a>
        <a asp-area="Admin" asp-controller="Content" asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Добавить баннер
        </a>
    </div>
</div>

<!-- Фильтры -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Тип баннера</label>
                <select name="typeFilter" class="form-select">
                    <option value="">Все типы</option>
                    @foreach (var type in Enum.GetValues<BannerType>())
                    {
                        <option value="@type" selected="@(Model.TypeFilter == type)">@GetBannerTypeDisplayName(type)</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Статус</label>
                <select name="isActiveFilter" class="form-select">
                    <option value="">Все</option>
                    <option value="true" selected="@(Model.IsActiveFilter == true)">Активные</option>
                    <option value="false" selected="@(Model.IsActiveFilter == false)">Неактивные</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Поиск</label>
                <input type="text" name="search" class="form-control" placeholder="Поиск по названию..." value="@Model.Search">
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-1"></i>Фильтровать
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Сообщения -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Баннеры -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Список баннеров</h5>
        <span class="badge bg-primary">Всего: @Model.TotalCount</span>
    </div>
    
    @if (Model.Banners.Any())
    {
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th width="50">Порядок</th>
                            <th>Изображение</th>
                            <th>Заголовок</th>
                            <th>Тип</th>
                            <th>Статус</th>
                            <th>Дата создания</th>
                            <th width="150">Действия</th>
                        </tr>
                    </thead>
                    <tbody id="sortable-banners">
                        @foreach (var banner in Model.Banners)
                        {
                            <tr data-id="@banner.Id">
                                <td>
                                    <span class="handle" style="cursor: move;">
                                        <i class="fas fa-bars text-muted"></i>
                                    </span>
                                    @banner.DisplayOrder
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(banner.ImageUrl))
                                    {
                                        <img src="@banner.ImageUrl" alt="@banner.Title" 
                                             style="width: 100px; height: 60px; object-fit: cover; border-radius: 4px;">
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center"
                                             style="width: 100px; height: 60px; border-radius: 4px;">
                                            <i class="fas fa-image text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <strong>@banner.Title</strong><br>
                                    <small class="text-muted">@(banner.Description?.Length > 50 ? banner.Description.Substring(0, 50) + "..." : banner.Description ?? "Нет описания")</small>
                                </td>
                                <td>
                                    <span class="badge 
                                        @(banner.BannerType == BannerType.MainCarousel ? "bg-primary" : 
                                          banner.BannerType == BannerType.Promotion ? "bg-warning" : 
                                          banner.BannerType == BannerType.Sidebar ? "bg-info" : "bg-secondary")">
                                        @GetBannerTypeDisplayName(banner.BannerType)
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-sm @(banner.IsActive ? "btn-success" : "btn-secondary") toggle-status"
                                            data-id="@banner.Id">
                                        @(banner.IsActive ? "Активен" : "Неактивен")
                                    </button>
                                </td>
                                <td>@banner.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-area="Admin" asp-controller="Content" asp-action="Edit" 
                                           asp-route-id="@banner.Id" class="btn btn-outline-primary" title="Редактировать">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="@banner.Link" target="_blank" class="btn btn-outline-info" 
                                           title="Перейти по ссылке" @(string.IsNullOrEmpty(banner.Link) ? "disabled" : "")>
                                            <i class="fas fa-external-link-alt"></i>
                                        </a>
                                        <button class="btn btn-outline-danger delete-banner" 
                                                data-id="@banner.Id" data-title="@banner.Title" title="Удалить">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Пагинация -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Навигация по страницам">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" 
                                   asp-area="Admin" asp-controller="Content" asp-action="Banners" 
                                   asp-route-page="@i" 
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-typeFilter="@Model.TypeFilter"
                                   asp-route-isActiveFilter="@Model.IsActiveFilter"
                                   asp-route-search="@Model.Search">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    }
    else
    {
        <div class="card-body text-center py-5">
            <i class="fas fa-images fa-3x text-muted mb-3"></i>
            <p class="text-muted mb-0">Баннеры не найдены</p>
            <a asp-area="Admin" asp-controller="Content" asp-action="Create" class="btn btn-primary mt-3">
                <i class="fas fa-plus me-1"></i>Создать первый баннер
            </a>
        </div>
    }
</div>

@functions {
    public string GetBannerTypeDisplayName(BannerType bannerType)
    {
        return bannerType switch
        {
            BannerType.MainCarousel => "Главная карусель",
            BannerType.Sidebar => "Боковой баннер",
            BannerType.Promotion => "Акционный баннер",
            BannerType.Information => "Информационный блок",
            _ => bannerType.ToString()
        };
    }
}

@section Scripts {
    <script>
        $(function() {
            // Переключение статуса
            $('.toggle-status').on('click', function() {
                const $btn = $(this);
                const bannerId = $btn.data('id');
                
                $.post('/Admin/Content/ToggleStatus/' + bannerId)
                    .done(function(data) {
                        if (data.success) {
                            if (data.isActive) {
                                $btn.removeClass('btn-secondary').addClass('btn-success').text('Активен');
                            } else {
                                $btn.removeClass('btn-success').addClass('btn-secondary').text('Неактивен');
                            }
                            showToast('success', 'Статус изменен', 'Статус баннера успешно обновлен');
                        }
                    })
                    .fail(function() {
                        showToast('error', 'Ошибка', 'Не удалось изменить статус');
                    });
            });
            
            // Удаление баннера
            $('.delete-banner').on('click', function() {
                const bannerId = $(this).data('id');
                const bannerTitle = $(this).data('title');
                
                if (confirm(`Вы уверены, что хотите удалить баннер "${bannerTitle}"?`)) {
                    $.post('/Admin/Content/Delete/' + bannerId, { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() })
                        .done(function() {
                            showToast('success', 'Успешно', 'Баннер удален');
                            setTimeout(() => location.reload(), 1500);
                        })
                        .fail(function() {
                            showToast('error', 'Ошибка', 'Не удалось удалить баннер');
                        });
                }
            });
            
            // Сортировка
            if ($('#sortable-banners').length) {
                $('#sortable-banners').sortable({
                    handle: '.handle',
                    update: function(event, ui) {
                        const orders = {};
                        $('#sortable-banners tr').each(function(index) {
                            const id = $(this).data('id');
                            orders[id] = index + 1;
                        });
                        
                        $.ajax({
                            url: '/Admin/Content/Reorder',
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify(orders),
                            headers: {
                                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                            },
                            success: function() {
                                showToast('success', 'Успешно', 'Порядок баннеров сохранен');
                                // Обновляем отображение порядка
                                $('#sortable-banners tr').each(function(index) {
                                    $(this).find('td:first').text(index + 1);
                                });
                            },
                            error: function() {
                                showToast('error', 'Ошибка', 'Не удалось сохранить порядок');
                            }
                        });
                    }
                });
            }
            
            function showToast(type, title, message) {
                const toastId = 'toast-' + Date.now();
                const toast = `<div id="${toastId}" class="toast align-items-center text-white bg-${type} border-0" role="alert">
                    <div class="d-flex">
                        <div class="toast-body">${message}</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>`;
                
                const $container = $('<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050"></div>');
                $container.html(toast);
                $('body').append($container);
                
                const toastEl = $container.find('.toast')[0];
                const bsToast = new bootstrap.Toast(toastEl);
                bsToast.show();
                
                setTimeout(() => {
                    bsToast.hide();
                    setTimeout(() => $container.remove(), 500);
                }, 3000);
            }
        });
    </script>
}