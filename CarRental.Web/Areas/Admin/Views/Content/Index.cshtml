@{
    ViewData["Title"] = "Управление контентом";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    </div>

    <!-- Карточки управления контентом -->
    <div class="row">
        <!-- Баннеры -->
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-images me-2"></i>
                        Баннеры
                    </h5>
                </div>
                <div class="card-body">
                    <p class="card-text">Управление баннерами на главной странице. Создавайте, редактируйте и упорядочивайте слайды карусели.</p>
                    
                    <div class="mt-4">
                        <a asp-area="Admin" asp-controller="Content" asp-action="Banners" class="btn btn-primary w-100">
                            <i class="fas fa-cogs me-1"></i>
                            Управление баннерами
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Текстовые блоки -->
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-file-alt me-2"></i>
                        Текстовые страницы
                    </h5>
                </div>
                <div class="card-body">
                    <p class="card-text">Управление статическими страницами сайта: «О компании», «Условия аренды», «Контакты» и другие. Редактируйте содержимое с помощью визуального редактора.</p>
                    <div class="mt-4">
                        <a asp-area="Admin" asp-controller="Page" asp-action="Index" class="btn btn-success w-100">
                            <i class="fas fa-pencil-alt me-1"></i>
                            Управление страницами
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Статистика -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3 mb-3">
                            <div class="display-6 text-primary">
                                <i class="fas fa-image"></i>
                            </div>
                            <h5>Баннеры</h5>
                            <a asp-area="Admin" asp-controller="Content" asp-action="Banners" class="btn btn-sm btn-outline-primary">Управление</a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="display-6 text-success">
                                <i class="fas fa-plus-circle"></i>
                            </div>
                            <h5>Создать</h5>
                            <a asp-area="Admin" asp-controller="Content" asp-action="Create" class="btn btn-sm btn-outline-success">Новый баннер</a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="display-6 text-warning">
                                <i class="fas fa-sort"></i>
                            </div>
                            <h5>Порядок</h5>
                            <a asp-area="Admin" asp-controller="Content" asp-action="Banners" class="btn btn-sm btn-outline-warning">Изменить порядок</a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="display-6 text-info">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <h5>Аналитика</h5>
                            <button class="btn btn-sm btn-outline-info" disabled>Скоро</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>