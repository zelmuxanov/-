@model CarRental.Web.ViewModels.Admin.AdminChatViewModel
@{
    ViewData["Title"] = "Управление чатами";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-comments me-2"></i>Активные чаты
                    @if (Model.UnreadChatsCount > 0)
                    {
                        <span class="badge bg-danger ms-2">@Model.UnreadChatsCount</span>
                    }
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush" id="chatList">
                    @foreach (var chat in Model.Chats)
                    {
                        <div class="list-group-item list-group-item-action chat-list-item @(chat.HasUnread ? "unread" : "")"
                            data-chat-id="@chat.Id">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div class="flex-grow-1" onclick="window.location.href='/Admin/Chat?chatId=@chat.Id'">
                                    <h6 class="mb-1">@chat.DisplayName</h6>
                                    <p class="mb-1 text-truncate">@chat.ContactInfo</p>
                                    <small class="text-muted">@chat.LastMessageAt?.ToString("HH:mm")</small>
                                </div>
                                <button class="btn btn-sm btn-link text-danger delete-chat-from-list" data-chat-id="@chat.Id" title="Удалить чат">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        @if (Model.CurrentChat != null)
        {
            <input type="hidden" id="adminChatId" value="@Model.CurrentChat.ChatId" />
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Чат с @Model.CurrentChat.DisplayName</h5>
                        <div>
                            @if (Model.CurrentChat.UserId.HasValue)
                            {
                                <a href="@Url.Action("Edit", "Users", new { area = "Admin", id = Model.CurrentChat.UserId })" class="btn-secondary-modern">
                                    <i class="fas fa-user"></i> Профиль клиента
                                </a>
                            }
                            <button class="btn-secondary-modern" id="closeChatBtn">Закрыть чат</button>
                            <button id="deleteChatBtn" class="btn-icon text-danger" title="Удалить чат" data-bs-toggle="tooltip"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                    <div class="mt-2 small text-muted">
                        @if (Model.CurrentChat.UserId.HasValue)
                        {
                            <span><i class="fas fa-envelope"></i> @Model.CurrentChat.ContactInfo</span>
                        }
                        else
                        {
                            <span><i class="fas fa-user-friends"></i> Гость</span>
                            if (!string.IsNullOrEmpty(Model.CurrentChat.ContactInfo))
                            {
                                <span> | @Model.CurrentChat.ContactInfo</span>
                            }
                        }
                    </div>
                    <!-- ❌ Удаляем второй такой же блок ниже -->
                </div>
                <div class="card-body">
                    <div id="chatMessages" style="height: 500px; overflow-y: auto;" class="mb-3">
                        @foreach (var message in Model.CurrentChat.Messages)
                        {
                            <div class="message @(message.IsUserMessage ? "user-message" : "admin-message") mb-2">
                                <div class="d-flex @(message.IsUserMessage ? "justify-content-start" : "justify-content-end")">
                                    <div class="message-content p-2 rounded @(message.IsUserMessage ? "bg-light" : "bg-primary text-white")">
                                        <div class="d-flex justify-content-between">
                                            <strong>@message.SenderName</strong>
                                            <small>@message.CreatedAt.ToString("HH:mm")</small>
                                        </div>
                                        <div>@message.Message</div>
                                        @if (!string.IsNullOrEmpty(message.AttachmentUrl))
                                        {
                                            if (message.AttachmentType?.StartsWith("image/") == true)
                                            {
                                                <div class="mt-2">
                                                    <img src="@message.AttachmentUrl" class="img-fluid rounded" style="max-height: 150px;" onclick="window.open(this.src)" />
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="mt-2">
                                                    <a href="@message.AttachmentUrl" target="_blank" class="btn btn-sm btn-outline-secondary">
                                                        <i class="fas fa-file"></i> Файл
                                                    </a>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <form id="adminMessageForm" enctype="multipart/form-data">
                        <input type="hidden" id="adminChatId" value="@Model.CurrentChat?.ChatId" />
                        <div class="input-group">
                            <input type="text" id="adminMessageInput" class="form-control" placeholder="Введите сообщение..." />
                            <button type="button" id="adminAttachButton" class="btn btn-outline-secondary" title="Прикрепить файл">
                                <i class="fas fa-paperclip"></i>
                            </button>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane"></i> Отправить
                            </button>
                        </div>
                        <input type="file" id="adminFileInput" style="display: none;" accept="image/*" />
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="fas fa-comments fa-3x text-muted mb-3"></i>
                    <h5>Выберите чат для просмотра</h5>
                    <p class="text-muted">Нажмите на чат в списке слева, чтобы начать общение</p>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @* <script src="~/lib/microsoft-signalr/signalr.min.js"></script> *@
    
    
    <script>
        var adminChatConfig = {
            currentChatId: '@Model.CurrentChat?.ChatId',
            isAdmin: true
        };
    </script>
}