@model CarRental.Web.ViewModels.Admin.PageIndexViewModel
@{
    ViewData["Title"] = "Управление страницами";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Создать страницу
    </a>
</div>

<!-- Фильтры -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Статус</label>
                <select name="isActive" class="form-select">
                    <option value="">Все</option>
                    <option value="true" selected="@(Model.IsActiveFilter == true)">Активные</option>
                    <option value="false" selected="@(Model.IsActiveFilter == false)">Неактивные</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Поиск</label>
                <input type="text" name="search" class="form-control" value="@Model.Search" placeholder="Название или URL" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-1"></i>Фильтровать
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Сообщения -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Таблица -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Список страниц</h5>
        <span class="badge bg-primary">Всего: @Model.TotalCount</span>
    </div>
    <div class="card-body">
        @if (Model.Pages.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Заголовок</th>
                            <th>URL</th>
                            <th>Статус</th>
                            <th>Дата создания</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Pages)
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td><a href="/page/@item.Slug" target="_blank">/@item.Slug</a></td>
                                <td>
                                    <button class="btn btn-sm @(item.IsActive ? "btn-success" : "btn-secondary") toggle-status"
                                            data-id="@item.Id">
                                        @(item.IsActive ? "Активна" : "Неактивна")
                                    </button>
                                </td>
                                <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Редактировать">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="/page/@item.Slug" target="_blank" class="btn btn-outline-info" title="Просмотр">
                                            <i class="fas fa-external-link-alt"></i>
                                        </a>
                                        <button class="btn btn-outline-danger delete-page" data-id="@item.Id" data-title="@item.Title" title="Удалить">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Пагинация -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize"
                                   asp-route-isActive="@Model.IsActiveFilter" asp-route-search="@Model.Search">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <p class="text-muted text-center py-5">Страницы не найдены</p>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            // Переключение статуса
            $('.toggle-status').on('click', function() {
                const btn = $(this);
                const id = btn.data('id');
                const token = $('input[name="__RequestVerificationToken"]').val();
                $.post('/Admin/Page/ToggleStatus/' + id, { __RequestVerificationToken: token })
                    .done(function(data) {
                        if (data.success) {
                            if (data.isActive) {
                                btn.removeClass('btn-secondary').addClass('btn-success').text('Активна');
                            } else {
                                btn.removeClass('btn-success').addClass('btn-secondary').text('Неактивна');
                            }
                        } else {
                            alert(data.message || 'Ошибка');
                        }
                    })
                    .fail(function() {
                        alert('Ошибка соединения');
                    });
            });

            // Удаление страницы
            $('.delete-page').on('click', function() {
                const id = $(this).data('id');
                const title = $(this).data('title');
                if (!confirm(`Удалить страницу "${title}"?`)) return;
                const token = $('input[name="__RequestVerificationToken"]').val();
                $.post('/Admin/Page/Delete/' + id, { __RequestVerificationToken: token })
                    .done(function(data) {
                        if (data.success) {
                            location.reload();
                        } else {
                            alert(data.message || 'Ошибка удаления');
                        }
                    })
                    .fail(function() {
                        alert('Ошибка соединения');
                    });
            });
        });
    </script>
}