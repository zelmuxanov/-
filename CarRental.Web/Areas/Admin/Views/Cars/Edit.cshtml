@model CarRental.Web.ViewModels.Admin.CarEditViewModel
@using CarRental.Domain.Enums
@{
    ViewData["Title"] = "Редактировать автомобиль";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <a href="@Url.Action("Index")" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Назад
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <h5>Ошибки валидации:</h5>
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form action="/Admin/Cars/Edit/@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id">

            <!-- БЛОК 1: Основная информация -->
            <div class="card mb-3">
                <div class="card-header"><h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Основная информация</h5></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3"><label class="form-label">Марка *</label><input type="text" name="Brand" value="@Model.Brand" class="form-control" required></div>
                            <div class="mb-3"><label class="form-label">Модель *</label><input type="text" name="Model" value="@Model.Model" class="form-control" required></div>
                            <div class="mb-3"><label class="form-label">Год выпуска *</label><input type="number" name="Year" value="@Model.Year" class="form-control" min="2000" max="@(DateTime.Now.Year + 1)" required></div>
                            <div class="mb-3"><label class="form-label">Цвет</label>
                                <select name="Color" class="form-select">
                                    <option value="">Выберите цвет</option>
                                    @foreach (var color in Model.AvailableColors) {
                                        <option value="@color" selected="@(color == Model.Color)">@color</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3"><label class="form-label">Класс *</label>
                                <select name="Class" class="form-select" required>
                                    <option value="">Выберите класс</option>
                                    @foreach (var carClass in Model.CarClasses) {
                                        <option value="@carClass" selected="@(carClass == Model.Class)">@GetCarClassDisplay(carClass)</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3"><label class="form-label">Тип топлива *</label>
                                <select name="FuelType" class="form-select" required>
                                    <option value="">Выберите тип топлива</option>
                                    @foreach (var fuelType in Model.FuelTypes) {
                                        <option value="@fuelType" selected="@(fuelType == Model.FuelType)">@GetFuelTypeDisplay(fuelType)</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3"><label class="form-label">Коробка передач *</label>
                                <select name="Transmission" class="form-select" required>
                                    <option value="">Выберите коробку передач</option>
                                    @foreach (var transmission in Model.TransmissionTypes) {
                                        <option value="@transmission" selected="@(transmission == Model.Transmission)">@GetTransmissionDisplay(transmission)</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4"><div class="mb-3"><label class="form-label">Госномер</label><input type="text" name="LicensePlate" id="LicensePlate" class="form-control" placeholder="А000АА000" value="@Model.LicensePlate" /></div></div>
                        <div class="col-md-4"><div class="mb-3"><label class="form-label">VIN</label><input type="text" name="VIN" id="VIN" class="form-control" maxlength="17" placeholder="17 символов" value="@Model.VIN" /></div></div>
                        <div class="col-md-4"><div class="mb-3"><label class="form-label">Количество мест *</label><input type="number" name="Seats" value="@Model.Seats" class="form-control" min="1" max="20" required></div></div>
                    </div>
                </div>
            </div>
            <!-- БЛОК 2: Цены, депозит, пробег -->
            <div class="card mb-3">
                <div class="card-header"><h5 class="mb-0"><i class="fas fa-ruble-sign me-2"></i>Цены, депозит и пробег</h5></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3"><div class="mb-3"><label class="form-label">Цена за сутки (₽) *</label><input type="number" name="PricePerDay" value="@Model.PricePerDay.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" class="form-control" min="1" required></div></div>
                        <div class="col-md-3"><div class="mb-3"><label class="form-label">Цена от 15 суток (₽)</label><input type="number" name="PricePerDay15" value="@Model.PricePerDay15.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" class="form-control" min="0" /></div></div>
                        <div class="col-md-3"><div class="mb-3"><label class="form-label">Цена от 30 суток (₽)</label><input type="number" name="PricePerDay30" value="@Model.PricePerDay30.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" class="form-control" min="0" /></div></div>
                        <div class="col-md-3"><div class="mb-3"><label class="form-label">Депозит (₽)</label><input type="number" name="Deposit" value="@Model.Deposit.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" class="form-control" min="0" /></div></div>
                    </div>
                    <div class="row">
                        <div class="col-md-4"><div class="mb-3"><label class="form-label">Лимит пробега (км/сут)</label><input type="number" name="MileageLimitPerDay" value="@Model.MileageLimitPerDay" class="form-control" min="0" /><small class="text-muted">Бесплатный суточный пробег</small></div></div>
                        <div class="col-md-4"><div class="mb-3"><label class="form-label">Цена безлимитного пробега (₽/сут)</label><input type="number" name="UnlimitedMileagePrice" value="@Model.UnlimitedMileagePrice.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" class="form-control" min="0" step="0.01" /><small class="text-muted">Стоимость опции «Безлимитный пробег» за сутки</small></div></div>
                        <div class="col-md-4"><div class="mb-3"><label class="form-label">Доплата за превышение километража (₽/км)</label><input type="number" name="OverMileagePricePerKm" value="@Model.OverMileagePricePerKm.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" class="form-control" min="0" step="0.01" /><small class="text-muted">Стоимость доплаты за выход из утвержденного тарифа по километражу</small></div></div>
                        <div class="col-md-4"><div class="mb-3"><label class="form-label">Объем двигателя (л) *</label><input type="text" name="EngineCapacityString" value="@Model.EngineCapacityString" class="form-control" required><small class="text-muted">Например: 1.6, 2.0, 3.5</small></div></div>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Описание</label>
                <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
            </div>

            <!-- Существующие изображения -->
            <div class="mb-3">
                <label class="form-label">Существующие фотографии</label>
                <div class="row" id="imageGallery">
                    @if (Model.ExistingImages != null && Model.ExistingImages.Any())
                    {
                        foreach (var img in Model.ExistingImages.OrderBy(i => i.DisplayOrder))
                        {
                            <div class="col-md-3 mb-3" data-image-id="@img.Id">
                                <div class="position-relative">
                                    <img src="@img.ImageUrl" class="img-thumbnail" style="height:150px; object-fit:cover; cursor:grab;" />
                                    @if (img.IsMain) { <span class="badge bg-success position-absolute top-0 end-0">Главное</span> }
                                    <div class="btn-group w-100 mt-1">
                                        <button class="btn btn-sm btn-outline-danger delete-image" data-id="@img.Id" type="button"><i class="fas fa-trash"></i></button>
                                        @if (!img.IsMain) { <button class="btn btn-sm btn-outline-primary set-main" data-id="@img.Id" type="button"><i class="fas fa-star"></i></button> }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            <!-- Новые фотографии -->
            <div class="mb-3">
                <label class="form-label">Добавить новые фотографии</label>
                <input type="file" name="ImageFiles" multiple accept=".jpg,.jpeg,.png,.gif" class="form-control" />
                <small class="text-muted">Удерживайте Ctrl для выбора нескольких файлов (до 10 всего). Первое новое фото станет главным, если нет других.</small>
            </div>

            <input type="hidden" name="IsAvailable" value="@Model.IsAvailable.ToString()" />

            <div class="d-flex justify-content-between">
                <a href="@Url.Action("Index")" class="btn btn-secondary">Отмена</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Сохранить изменения
                </button>
            </div>
        </form>
    </div>
</div>

@functions {
    string GetCarClassDisplay(CarClass carClass) => carClass switch
    {
        CarClass.Standard => "Стандарт",
        CarClass.SUV => "Кроссовер",
        CarClass.Business => "Бизнес",
        CarClass.Minivan => "Минивэн",
        _ => carClass.ToString()
    };
    string GetFuelTypeDisplay(FuelType fuelType) => fuelType switch
    {
        FuelType.Petrol => "Бензин",
        FuelType.Diesel => "Дизель",
        FuelType.Hybrid => "Гибрид",
        _ => fuelType.ToString()
    };
    string GetTransmissionDisplay(TransmissionType transmission) => transmission switch
    {
        TransmissionType.Manual => "Механика",
        TransmissionType.Automatic => "Автомат",
        _ => transmission.ToString()
    };
}

@section Scripts {
    <script src="~/lib/sortable/Sortable.min.js"></script>
        <script>
        $(function() {
            var token = $('input[name="__RequestVerificationToken"]').val();

            // Удаление изображения
            $('#imageGallery').on('click', '.delete-image', function() {
                var id = $(this).data('id');
                var $item = $(this).closest('[data-image-id]');
                if (!confirm('Удалить изображение?')) return;
                $.post('/Admin/Cars/delete-image/' + id, { __RequestVerificationToken: token }, function(res) {
                    if (res.success) $item.remove();
                });
            });

            // Назначить главным
            $('#imageGallery').on('click', '.set-main', function() {
                var id = $(this).data('id');
                $.post('/Admin/Cars/set-main-image/' + id, { __RequestVerificationToken: token }, function(res) {
                    if (res.success) location.reload();
                });
            });

            // Drag-and-drop с сохранением полного порядка
            var gallery = document.getElementById('imageGallery');
            if (gallery) {
                new Sortable(gallery, {
                    animation: 150,
                    ghostClass: 'bg-light',
                    handle: '.img-thumbnail',
                    onEnd: function(evt) {
                        var items = gallery.children;
                        var orderedIds = [];
                        for (var i = 0; i < items.length; i++) {
                            var id = items[i].getAttribute('data-image-id');
                            if (id) orderedIds.push(id);
                        }
                        $.ajax({
                            url: '/Admin/Cars/update-images-order',
                            type: 'POST',
                            contentType: 'application/json',
                            headers: { 'RequestVerificationToken': token },
                            data: JSON.stringify(orderedIds),
                            success: function(res) {
                                if (!res.success) console.warn('Ошибка обновления порядка');
                            },
                            error: function() {
                                console.error('Ошибка соединения при обновлении порядка');
                            }
                        });
                    }
                });
            } else {
                console.error('Контейнер #imageGallery не найден!');
            }
        });
    </script>
    <script>
    $(document).ready(function() {
            $('#LicensePlate').inputmask({
                mask: 'A999AA99[9]',
                definitions: {
                    'A': { validator: '[A-Za-zА-Яа-я]', casing: 'upper' }
                },
                placeholder: '0',
                clearIncomplete: true
            });
            
            $('#VIN').inputmask({
                mask: '*****************',
                definitions: { '*': { validator: '[A-Z0-9]', casing: 'upper' } },
                placeholder: '_',
                clearIncomplete: false
            });
        });
    </script>
}