@model IEnumerable<CarRental.BLL.DTOs.Car.CarDto>
@using CarRental.Web.HtmlHelpers
@{
    ViewData["Title"] = "Управление автомобилями";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css" />
    <style>
        /* Стили для flatpickr внутри модалки */
        .flatpickr-calendar {
            z-index: 1060 !important;
            background: #1f2937 !important;
            border-color: #374151 !important;
        }
        .flatpickr-day, .flatpickr-weekday, .flatpickr-month {
            color: #fff !important;
        }
        .flatpickr-day.selected {
            background: #3b82f6 !important;
            border-color: #3b82f6 !important;
        }
        .flatpickr-day.disabled {
            color: #6b7280 !important;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <div>
        <a href="@Url.Action("Create")" class="btn-primary-modern">
            <i class="fas fa-plus"></i> Добавить автомобиль
        </a>
        <a href="@Url.Action("ExportCars", "ImportExport")" class="btn-secondary-modern">
            <i class="fas fa-file-excel"></i> Экспорт списка
        </a>
        <a href="@Url.Action("ImportCars", "ImportExport")" class="btn-secondary-modern">
            <i class="fas fa-upload"></i> Импорт автомобилей
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Фото</th>
                    <th>Автомобиль</th>
                    <th>Класс</th>
                    <th>Цена/сутки</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var car in Model)
                {
                    <tr>
                        <td style="width: 100px;">
                            @if (!string.IsNullOrEmpty(car.MainImageUrl))
                            {
                                <img src="@car.MainImageUrl" alt="@car.Brand @car.Model" 
                                     class="img-fluid rounded" style="max-width: 80px; max-height: 60px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="text-center text-muted" style="width: 80px; height: 60px; line-height: 60px; background: #f8f9fa;">
                                    <i class="fas fa-car"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <strong>@car.Brand @car.Model</strong><br>
                            <small class="text-muted">
                                @car.Year год, @car.Color<br>
                            </small>
                         </td>
                        <td>@GetCarClassDisplay(car.Class)</td>
                        <td>@car.PricePerDay.ToString("N0") ₽/день</td>
                        <td>
                            @if (car.IsAvailable)
                            {
                                <span class="badge bg-success">Доступен</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Недоступен</span>
                            }
                         </td>
                        <td>
                            <div class="actions-group">
                                <a href="@Url.Action("Details", new { id = car.Id })" class="btn-icon" title="Просмотр" data-bs-toggle="tooltip"><i class="fas fa-eye"></i></a>
                                <a href="@Url.Action("Edit", new { id = car.Id })" class="btn-icon" title="Редактировать" data-bs-toggle="tooltip"><i class="fas fa-edit"></i></a>
                                <button type="button" class="btn-icon text-success create-booking-btn" data-car-id="@car.Id" data-car-name="@car.Brand @car.Model" title="Создать бронь" data-bs-toggle="tooltip"><i class="fas fa-calendar-plus"></i></button>
                                <form method="post" action="@Url.Action("ToggleAvailability", new { id = car.Id })" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-icon text-warning" title="@(car.IsAvailable ? "Сделать недоступным" : "Сделать доступным")" data-bs-toggle="tooltip"><i class="fas fa-ban"></i></button>
                                </form>
                                <form method="post" action="@Url.Action("Delete", new { id = car.Id })" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-icon text-danger" title="Удалить" data-bs-toggle="tooltip" onclick="return confirm('Удалить этот автомобиль?');"><i class="fas fa-trash"></i></button>
                                </form>
                            </div>
                         </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-car fa-3x text-muted mb-3"></i>
        <p class="text-muted">Автомобили не найдены</p>
        <a href="@Url.Action("Create")" class="btn btn-primary">Добавить первый автомобиль</a>
    </div>
}

<div class="mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title">Всего автомобилей</h6>
                    <h4 class="card-text">@Model.Count()</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title">Доступно для аренды</h6>
                    <h4 class="card-text">@Model.Count(c => c.IsAvailable)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6 class="card-title">Средняя цена/сутки</h6>
                    <h4 class="card-text">@(Model.Any() ? Model.Average(c => c.PricePerDay).ToString("N0") : "0") ₽</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h6 class="card-title">Разных классов</h6>
                    <h4 class="card-text">@Model.Select(c => c.Class).Distinct().Count()</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно для создания брони (только системный пользователь) -->
<div class="modal fade" id="adminBookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Создание бронирования</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="adminBookingForm">
                    <input type="hidden" id="bookingCarId" name="CarId" />
                    <div class="mb-3">
                        <label class="form-label">Автомобиль</label>
                        <p class="form-control-plaintext" id="bookingCarName"></p>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Дата начала</label>
                            <input type="text" id="bookingStartDate" name="StartDate" class="form-control" placeholder="Выберите дату" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Дата окончания</label>
                            <input type="text" id="bookingEndDate" name="EndDate" class="form-control" placeholder="Выберите дату" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Статус</label>
                        <select id="bookingStatus" name="Status" class="form-select">
                            <option value="1">Подтверждено</option>
                            <option value="0">На рассмотрении</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Примечания</label>
                        <textarea id="bookingNotes" name="Notes" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="alert alert-info small">
                        <i class="fas fa-info-circle me-1"></i> Бронирование будет создано от имени системного пользователя.
                    </div>
                </form>
                <div class="d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" id="submitAdminBooking" class="btn btn-primary">Создать бронь</button>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetCarClassDisplay(CarClass carClass) => carClass switch
    {
        CarClass.Standard => "Стандарт",
        CarClass.SUV => "Кроссовер",
        CarClass.Business => "Бизнес",
        CarClass.Minivan => "Минивэн",
        _ => carClass.ToString()
    };
}

@section Scripts {
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/ru.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // ---- Элементы ----
            const modalElem = document.getElementById('adminBookingModal');
            const modal = new bootstrap.Modal(modalElem);
            const carIdInput = document.getElementById('bookingCarId');
            const carNameSpan = document.getElementById('bookingCarName');
            const startDateInput = document.getElementById('bookingStartDate');
            const endDateInput = document.getElementById('bookingEndDate');
            const statusSelect = document.getElementById('bookingStatus');
            const notesInput = document.getElementById('bookingNotes');
            const submitBtn = document.getElementById('submitAdminBooking');
            
            // CSRF-токен из лейаута
            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (!csrfToken) console.warn('CSRF token not found');
            
            // Переменные для flatpickr
            let fpStart = null, fpEnd = null;
            
            // ---- Открытие модалки с конкретным авто ----
            document.querySelectorAll('.create-booking-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const carId = this.getAttribute('data-car-id');
                    const carName = this.getAttribute('data-car-name');
                    carIdInput.value = carId;
                    carNameSpan.textContent = carName;
                    
                    // Сброс полей
                    if (fpStart) fpStart.setDate(null);
                    if (fpEnd) fpEnd.setDate(null);
                    startDateInput.value = '';
                    endDateInput.value = '';
                    notesInput.value = '';
                    statusSelect.value = '1';  // по умолчанию "Подтверждено"
                    
                    modal.show();
                });
            });
            
            // ---- Инициализация flatpickr при открытии модалки ----
            modalElem.addEventListener('shown.bs.modal', function () {
                if (fpStart) fpStart.destroy();
                if (fpEnd) fpEnd.destroy();
                
                fpStart = flatpickr(startDateInput, {
                    dateFormat: 'Y-m-d',
                    locale: 'ru',
                    minDate: 'today',
                    static: true,
                    onChange: function(selectedDates) {
                        if (selectedDates.length && fpEnd) {
                            fpEnd.set('minDate', selectedDates[0]);
                        }
                    }
                });
                fpEnd = flatpickr(endDateInput, {
                    dateFormat: 'Y-m-d',
                    locale: 'ru',
                    minDate: new Date().fp_incr(1),
                    static: true
                });
            });
            
            // ---- Отправка бронирования ----
            submitBtn.addEventListener('click', async function() {
                const carId = carIdInput.value;
                if (!carId) {
                    alert('Ошибка: автомобиль не выбран');
                    return;
                }
                const start = startDateInput.value;
                const end = endDateInput.value;
                if (!start || !end) {
                    alert('Выберите даты');
                    return;
                }
                if (new Date(start) >= new Date(end)) {
                    alert('Дата начала должна быть раньше даты окончания');
                    return;
                }
                
                // Преобразуем в UTC ISO
                const startUTC = new Date(start + 'T00:00:00').toISOString();
                const endUTC = new Date(end + 'T00:00:00').toISOString();
                
                const payload = {
                    CarId: carId,
                    UserId: null,                     // системный пользователь (на сервере подставится)
                    StartDate: startUTC,
                    EndDate: endUTC,
                    TotalPrice: null,
                    Notes: notesInput.value,
                    Status: parseInt(statusSelect.value, 10)
                };
                
                try {
                    const response = await fetch('/Admin/Calendar/CreateBooking', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': csrfToken
                        },
                        body: JSON.stringify(payload)
                    });
                    const result = await response.json();
                    if (result.success) {
                        modal.hide();
                        alert('Бронь успешно создана');
                    } else {
                        alert(result.message || 'Ошибка создания брони');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Ошибка сети или сервера');
                }
            });
        });
    </script>
}