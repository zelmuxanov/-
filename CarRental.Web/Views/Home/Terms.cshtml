@{
    ViewData["Title"] = "Условия оферты";
    Layout = "_Layout";
}

<div class="container-xxl py-4">
    <h2 class="mb-4">Договор публичной оферты</h2>
    <div class="pdf-viewer">
        <iframe src="~/documents/oferta.pdf" allowfullscreen></iframe>
    </div>
    <div class="mt-3">
        <a href="~/documents/oferta.pdf" download class="btn btn-primary">
            <i class="fas fa-download me-2"></i>Скачать PDF
        </a>
    </div>
</div>

<style>
    .pdf-viewer {
        width: 100%;
        height: calc(100vh - 200px); /* динамическая высота с учётом заголовка и кнопки */
        min-height: 500px;           /* минимальная высота для маленьких экранов */
        border: 1px solid #dee2e6;  /* опционально – видимая граница */
        border-radius: 0.375rem;
        overflow: auto;              /* собственная прокрутка на случай, если iframe не справится */
        background: #f8f9fa;
    }

    .pdf-viewer iframe {
        width: 100%;
        height: 100%;
        border: 0;
        display: block;
    }
</style>