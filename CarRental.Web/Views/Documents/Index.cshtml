@model CarRental.Web.ViewModels.DocumentsIndexViewModel
@using CarRental.Domain.Enums
@{
    ViewData["Title"] = "Мои документы";
    Layout = "_Layout";
}

<div class="container-xxl py-4">
    <div class="row">
        <!-- Боковая навигация (как в профиле) -->
        <div class="col-lg-3">
            <div class="profile-sidebar">
                <div class="profile-sidebar-header p-3 border-bottom">
                    <h6 class="mb-0" style="color: var(--text-primary);">Навигация</h6>
                </div>
                <div class="profile-sidebar-body">
                    <a href="@Url.Action("Index", "Profile")" class="profile-nav-item-modern">
                        <i class="fas fa-home profile-nav-icon"></i><span>Обзор</span>
                    </a>
                    <a href="@Url.Action("Edit", "Profile")" class="profile-nav-item-modern">
                        <i class="fas fa-user-edit profile-nav-icon"></i><span>Редактировать профиль</span>
                    </a>
                    <a href="@Url.Action("Index", "Documents")" class="profile-nav-item-modern active">
                        <i class="fas fa-file-contract profile-nav-icon"></i><span>Документы</span>
                    </a>
                    <a href="@Url.Action("Bookings", "Profile")" class="profile-nav-item-modern">
                        <i class="fas fa-calendar profile-nav-icon"></i><span>Мои бронирования</span>
                    </a>
                    <a href="@Url.Action("ChangePassword", "Profile")" class="profile-nav-item-modern">
                        <i class="fas fa-lock profile-nav-icon"></i><span>Смена пароля</span>
                    </a>
                    <a href="/Car" class="profile-nav-item-modern">
                        <i class="fas fa-search profile-nav-icon"></i><span>Найти автомобиль</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            <h2 class="mb-4">Мои документы</h2>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            <div class="row g-4 mb-4">
                <!-- Паспорт -->
                <div class="col-md-6">
                    <div class="card-modern h-100">
                        <div class="card-body-modern">
                            <h5 class="mb-3"><i class="fas fa-passport text-primary me-2"></i>Паспорт</h5>
                            @if (Model.Passport != null)
                            {
                                var doc = Model.Passport;
                                <div class="mb-2">
                                    <span class="badge @GetStatusBadgeClass(doc.Status)">@GetStatusText(doc.Status)</span>
                                </div>
                                <p><strong>Номер:</strong> @doc.DocumentNumber</p>
                                <p><strong>Выдан:</strong> @doc.IssueDate?.ToShortDateString()</p>
                                <p><strong>Кем выдан:</strong> @doc.IssuedBy</p>
                                <p><strong>Дата рождения:</strong> @doc.BirthDate</p>
                                <p><strong>Место рождения:</strong> @doc.PlaceOfBirth</p>
                                @if (!string.IsNullOrEmpty(doc.RegistrationAddress))
                                {
                                    <p><strong>Адрес регистрации:</strong> @doc.RegistrationAddress</p>
                                }
                                <div class="btn-group-vertical w-100 mt-3">
                                    <a href="@doc.FileUrl" target="_blank" class="btn btn-outline-primary mb-2">
                                        <i class="fas fa-eye"></i> Лицевая сторона
                                    </a>
                                    @if (!string.IsNullOrEmpty(doc.FileUrl2))
                                    {
                                        <a href="@doc.FileUrl2" target="_blank" class="btn btn-outline-secondary mb-2">
                                            <i class="fas fa-eye"></i> Прописка
                                        </a>
                                    }
                                    @if (doc.Status == "Rejected")
                                    {
                                        <a href="@Url.Action("Upload", new { type = DocumentType.Passport })" class="btn btn-outline-warning">
                                            <i class="fas fa-redo"></i> Заменить
                                        </a>
                                    }
                                    else if (doc.Status == "Pending")
                                    {
                                        <form asp-action="Delete" asp-route-id="@doc.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger w-100">Удалить</button>
                                        </form>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">Документ не загружен</p>
                                <a href="@Url.Action("Upload", new { type = DocumentType.Passport })" class="btn btn-primary w-100 mt-3">
                                    <i class="fas fa-upload me-2"></i>Загрузить паспорт
                                </a>
                            }
                        </div>
                    </div>
                </div>

                <!-- Водительское удостоверение -->
                <div class="col-md-6">
                    <div class="card-modern h-100">
                        <div class="card-body-modern">
                            <h5 class="mb-3"><i class="fas fa-id-card text-success me-2"></i>Водительское удостоверение</h5>
                            @if (Model.DriverLicense != null)
                            {
                                var doc = Model.DriverLicense;
                                <div class="mb-2">
                                    <span class="badge @GetStatusBadgeClass(doc.Status)">@GetStatusText(doc.Status)</span>
                                </div>
                                <p><strong>Номер:</strong> @doc.DocumentNumber</p>
                                <p><strong>Выдано:</strong> @doc.IssueDate?.ToShortDateString()</p>
                                <p><strong>Действительно до:</strong> @doc.ExpiryDate?.ToShortDateString()</p>
                                <div class="btn-group-vertical w-100 mt-3">
                                    <a href="@doc.FileUrl" target="_blank" class="btn btn-outline-primary mb-2">
                                        <i class="fas fa-eye"></i> Лицевая сторона
                                    </a>
                                    @if (!string.IsNullOrEmpty(doc.FileUrl2))
                                    {
                                        <a href="@doc.FileUrl2" target="_blank" class="btn btn-outline-secondary mb-2">
                                            <i class="fas fa-eye"></i> Оборотная сторона
                                        </a>
                                    }
                                    @if (doc.Status == "Rejected")
                                    {
                                        <a href="@Url.Action("Upload", new { type = DocumentType.DriverLicense })" class="btn btn-outline-warning">
                                            <i class="fas fa-redo"></i> Заменить
                                        </a>
                                    }
                                    else if (doc.Status == "Pending")
                                    {
                                        <form asp-action="Delete" asp-route-id="@doc.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger w-100">Удалить</button>
                                        </form>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">Документ не загружен</p>
                                <a href="@Url.Action("Upload", new { type = DocumentType.DriverLicense })" class="btn btn-primary w-100 mt-3">
                                    <i class="fas fa-upload me-2"></i>Загрузить права
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Другие документы (если есть) -->
            @if (Model.OtherDocuments.Any())
            {
                <h4 class="mt-4 mb-3">Другие документы</h4>
                <div class="list-group">
                    @foreach (var doc in Model.OtherDocuments)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <strong>@doc.DocumentType</strong> - @doc.DocumentNumber
                                    <span class="badge @GetStatusBadgeClass(doc.Status) ms-2">@GetStatusText(doc.Status)</span>
                                </div>
                                <div>
                                    <a href="@doc.FileUrl" target="_blank" class="btn btn-sm btn-outline-secondary">Просмотр</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status) => status switch
    {
        "Pending" => "bg-warning",
        "Verified" => "bg-success",
        "Rejected" => "bg-danger",
        _ => "bg-secondary"
    };
    string GetStatusText(string status) => status switch
    {
        "Pending" => "На проверке",
        "Verified" => "Подтверждён",
        "Rejected" => "Отклонён",
        _ => status
    };
}