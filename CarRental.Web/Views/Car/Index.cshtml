@model IEnumerable<CarRental.BLL.DTOs.Car.CarDto>
@using CarRental.Domain.Enums

@{
    ViewData["Title"] = "Каталог автомобилей";
    Layout = "_Layout";
}

<div class="container-xxl mt-4">
    <h1 class="mb-4">Каталог автомобилей</h1>

    <!-- Современная панель фильтров -->
    <div class="filter-section-modern mb-5">
        <div class="filter-header">
            <h5 class="mb-0">Поиск автомобилей</h5>
            <button class="filter-advanced-btn" type="button" 
                    data-bs-toggle="collapse" data-bs-target="#advancedFilters">
                <i class="fas fa-filter"></i> Расширенный поиск
            </button>
        </div>

        <form method="get" action="@Url.Action("Search", "Car")" id="searchForm">
            <!-- Основные фильтры -->
            <div class="filter-grid">
                <div>
                    <label class="form-label">Сортировка</label>
                    <select name="sortBy" class="form-select" id="sortSelect">
                        <option value="">По умолчанию</option>
                        <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc")">Цена ↑</option>
                        <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc")">Цена ↓</option>
                    </select>
                </div>

                <div>
                    <label class="form-label">Марка</label>
                    <select name="brand" class="form-select" id="brandSelect">
                        <option value="">Все марки</option>
                        @if (ViewBag.Brands != null)
                        {
                            @foreach (var brand in ViewBag.Brands)
                            {
                                var isSelected = ViewBag.CurrentBrand == brand;
                                <option value="@brand" selected="@isSelected">@brand</option>
                            }
                        }
                    </select>
                </div>
                
                <div>
                    <label class="form-label">Модель</label>
                    <select name="model" class="form-select" id="modelSelect">
                        <option value="">Все модели</option>
                        @if (ViewBag.Models != null)
                        {
                            @foreach (var modelItem in ViewBag.Models)
                            {
                                var isSelected = ViewBag.CurrentModel == modelItem;
                                <option value="@modelItem" selected="@isSelected">@modelItem</option>
                            }
                        }
                    </select>
                </div>
                
                <div>
                    <label class="form-label">Класс авто</label>
                    <select name="class" class="form-select" id="classSelect">
                        <option value="">Все классы</option>
                        @if (ViewBag.Classes != null)
                        {
                            foreach (var carClass in ViewBag.Classes)
                            {
                                var isSelected = ViewBag.CurrentClass == carClass.ToString();
                                <option value="@carClass" selected="@isSelected">@GetCarClassName(carClass)</option>
                            }
                        }
                    </select>
                </div>
                
                <div class="d-flex align-items-end">
                    <button type="submit" class="btn-primary-modern btn-modern w-100">
                        <i class="fas fa-search"></i> Поиск
                    </button>
                </div>
            </div>

            <!-- Расширенные фильтры -->
            <div class="collapse mt-4" id="advancedFilters">
                <hr class="my-3">
                <h6 class="mb-3"><i class="fas fa-filter"></i> Дополнительные фильтры</h6>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Макс. цена</label>
                        <div class="input-group">
                            <input type="number" name="maxPrice" class="form-control" 
                                placeholder="Макс. цена" value="@ViewBag.CurrentMaxPrice" id="maxPriceInput">
                            <span class="input-group-text">₽/сут</span>
                        </div>
                    </div>
                    
                    <div class="col-md-3">
                        <label class="form-label">Тип топлива</label>
                        <select name="fuelType" class="form-select" id="fuelSelect">
                            <option value="">Все типы</option>
                            @if (ViewBag.FuelTypes != null)
                            {
                                foreach (var fuelType in ViewBag.FuelTypes)
                                {
                                    var isSelected = ViewBag.CurrentFuelType == fuelType.ToString();
                                    <option value="@fuelType" selected="@isSelected">@GetFuelTypeName(fuelType)</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <div class="col-md-3">
                        <label class="form-label">Коробка передач</label>
                        <select name="transmission" class="form-select" id="transmissionSelect">
                            <option value="">Все типы</option>
                            @if (ViewBag.Transmissions != null)
                            {
                                foreach (var transmission in ViewBag.Transmissions)
                                {
                                    var isSelected = ViewBag.CurrentTransmission == transmission.ToString();
                                    <option value="@transmission" selected="@isSelected">@GetTransmissionName(transmission)</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <div class="col-md-3">
                        <label class="form-label">Количество мест</label>
                        <select name="minSeats" class="form-select" id="seatsSelect">
                            <option value="">Любое</option>
                            @for (int i = 2; i <= 8; i += 2)
                            {
                                var isSelected = ViewBag.CurrentMinSeats == i.ToString();
                                <option value="@i" selected="@isSelected">От @i мест</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Кнопка сброса -->
            @if (ViewBag.HasActiveFilters == true)
            {
                <div class="mt-3">
                    <a href="@Url.Action("Index")" class="btn-outline-modern btn-modern">
                        <i class="fas fa-times"></i> Сбросить все фильтры
                    </a>
                </div>
            }
        </form>
    </div>

    <!-- Статистика поиска -->
    @if (ViewBag.HasActiveFilters == true)
    {
        <div class="alert alert-info mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <strong><i class="fas fa-chart-bar"></i> Результаты поиска:</strong>
                    <span class="ms-2">
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentBrand))
                        {
                            <span class="badge bg-primary me-1">Марка: @ViewBag.CurrentBrand</span>
                        }
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentModel))
                        {
                            <span class="badge bg-primary me-1">Модель: @ViewBag.CurrentModel</span>
                        }
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentClass))
                        {
                            <span class="badge bg-success me-1">@GetCarClassName(ViewBag.CurrentClass)</span>
                        }
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentSort))
                        {
                            <span class="badge bg-warning me-1">@GetSortName(ViewBag.CurrentSort)</span>
                        }
                    </span>
                </div>
                <span class="fw-bold">
                    <i class="fas fa-car"></i> Найдено: 
                    <span class="text-primary">@(Model?.Count() ?? 0)</span> автомобилей
                </span>
            </div>
        </div>
    }

    <!-- Заголовок результатов -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1">
                @if (ViewBag.HasActiveFilters == true)
                {
                    <text>Найденные автомобили</text>
                }
                else
                {
                    <text>Все автомобили</text>
                }
            </h2>
            <p class="text-muted">
                @if (ViewBag.HasActiveFilters == true)
                {
                    <text>Результаты поиска по вашим критериям</text>
                }
                else
                {
                    <text>Полный каталог доступных автомобилей</text>
                }
            </p>
        </div>
    </div>

    <!-- Список автомобилей в современном стиле -->
    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var car in Model)
            {
                <div class="col-md-4">
                    <div class="card-modern car-card-modern">
                        <div class="car-image-container">
                            <a href="@Url.Action("Details", "Car", new { id = car.Id })">
                                @if (car.Images != null && car.Images.Any())
                                {
                                    var mainImage = car.Images.FirstOrDefault(i => i.IsMain) ?? car.Images.First();
                                    <img src="@mainImage.ImageUrl" class="car-image" alt="@car.Brand @car.Model" loading="lazy">
                                }
                                else
                                {
                                    <div class="car-image bg-secondary d-flex align-items-center justify-content-center">
                                        <i class="fas fa-car fa-3x text-muted"></i>
                                    </div>
                                }
                            </a>
                            <span class="car-badge">@GetCarClassName(car.Class.ToString())</span>
                        </div>
                        
                        <div class="card-body-modern d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="mb-0">@car.Brand @car.Model</h5>
                                <span class="badge @(car.IsAvailable ? "bg-success" : "bg-danger")">
                                    @(car.IsAvailable ? "Доступен" : "Занят")
                                </span>
                            </div>
                            
                            <div class="car-details-grid">
                                <div class="car-detail-item">
                                    <span class="car-detail-label">Год</span>
                                    <span class="car-detail-value">@car.Year</span>
                                </div>
                                <div class="car-detail-item">
                                    <span class="car-detail-label">Коробка</span>
                                    <span class="car-detail-value">@GetTransmissionName(car.Transmission.ToString())</span>
                                </div>
                                <div class="car-detail-item">
                                    <span class="car-detail-label">Топливо</span>
                                    <span class="car-detail-value">@GetFuelTypeName(car.FuelType.ToString())</span>
                                </div>
                                <div class="car-detail-item">
                                    <span class="car-detail-label">Мест</span>
                                    <span class="car-detail-value">@car.Seats</span>
                                </div>
                            </div>
                            
                            <div class="mt-auto pt-3">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="car-price-modern">
                                        от @car.PricePerDay30.ToString("C0")
                                        <span class="d-block">в сутки</span>
                                    </div>
                                </div>
                                
                                <a href="@Url.Action("Details", "Car", new { id = car.Id })" 
                                   class="btn-primary-modern btn-modern w-100">
                                    Подробнее об автомобиле
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center py-5">
            <i class="fas fa-search fa-3x mb-3 text-warning"></i>
            <h4>Автомобили не найдены</h4>
            <p>Попробуйте изменить критерии поиска или сбросить фильтры.</p>
            <div class="mt-3">
                <a href="@Url.Action("Index")" class="btn-primary-modern btn-modern">
                    <i class="fas fa-redo"></i> Сбросить фильтры
                </a>
            </div>
        </div>
    }
</div>

@functions {
    string GetCarClassName(string carClass)
    {
        return carClass switch
        {
            "Standard" => "Стандарт",
            "SUV" => "Кроссовер",
            "Business" => "Бизнес",
            "Minivan" => "Минивэн",
            _ => carClass
        };
    }
    
    string GetFuelTypeName(string fuelType)
    {
        return fuelType switch
        {
            "Petrol" => "Бензин",
            "Diesel" => "Дизель",
            "Hybrid" => "Гибрид",
            _ => fuelType
        };
    }
    
    string GetTransmissionName(string transmission)
    {
        return transmission switch
        {
            "Manual" => "Механика",
            "Automatic" => "Автомат",
            _ => transmission
        };
    }
    
    string GetSortName(string sort)
    {
        return sort switch
        {
            "price_asc" => "Цена по возрастанию",
            "price_desc" => "Цена по убыванию",
            _ => sort
        };
    }
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Сохраняем состояние расширенных фильтров
            const advancedFiltersOpen = localStorage.getItem('carFiltersOpen') === 'true';
            const collapseElement = document.getElementById('advancedFilters');
            
            if (collapseElement && advancedFiltersOpen) {
                new bootstrap.Collapse(collapseElement, { show: true });
            }
            
            collapseElement?.addEventListener('show.bs.collapse', () => {
                localStorage.setItem('carFiltersOpen', 'true');
            });
            
            collapseElement?.addEventListener('hide.bs.collapse', () => {
                localStorage.setItem('carFiltersOpen', 'false');
            });
            
            // Автоотправка формы при изменении основных фильтров
            const autoSubmitElements = ['sortSelect', 'brandSelect', 'modelSelect', 'classSelect', 'maxPriceInput'];
            
            autoSubmitElements.forEach(id => {
                const element = document.getElementById(id);
                if (element) {
                    element.addEventListener('change', () => {
                        document.getElementById('searchForm').submit();
                    });
                }
            });
        });
    </script>
}