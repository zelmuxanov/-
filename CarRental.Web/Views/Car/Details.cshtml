@section Scripts {
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/ru.js"></script>
    <script>
        // ========== ГОСТЕВОЕ БРОНИРОВАНИЕ (с расчётом) ==========
        (function() {
            const modalElement = document.getElementById('guestBookingModal');
            if (!modalElement) return;

            let fpStart = null, fpEnd = null;
            const pricePerDay = @pricePerDayJs;
            const pricePerDay15 = @pricePerDay15Js;
            const pricePerDay30 = @pricePerDay30Js;
            const deposit = @depositJs;
            const unlimitedPricePerDay = @unlimitedMileagePriceJs;
            const overMileagePricePerKm = @overMileagePriceJs;
            const mileageLimit = @mileageLimitJs;

            const startInput = document.getElementById('guestStartDate');
            const endInput = document.getElementById('guestEndDate');
            const needDelivery = document.getElementById('guestNeedDelivery');
            const deliveryOptions = document.getElementById('guestDeliveryOptions');
            const deliveryLocation = document.getElementById('guestDeliveryLocation');
            const unlimitedMileage = document.getElementById('guestUnlimitedMileage');
            const rentalPeriodEl = document.getElementById('guestRentalPeriod');
            const totalPriceEl = document.getElementById('guestTotalPrice');
            const priceBreakdownEl = document.getElementById('guestPriceBreakdown');
            const agreeCheck = document.getElementById('guestAgreeTerms');
            const submitBtn = document.getElementById('guestSubmitBtn');
            const form = document.getElementById('guestBookingForm');

            function destroyFlatpickr() {
                if (fpStart) { fpStart.destroy(); fpStart = null; }
                if (fpEnd) { fpEnd.destroy(); fpEnd = null; }
            }

            modalElement.addEventListener('shown.bs.modal', function() {
                destroyFlatpickr();

                // Показываем плейсхолдеры
                startInput.placeholder = "Загрузка...";
                endInput.placeholder = "Загрузка...";

                // Загружаем занятые даты
                fetch('/api/bookings/occupied-dates?carId=@car?.Id')
                    .then(r => r.ok ? r.json() : Promise.reject('Ошибка сервера'))
                    .then(disabledDates => {
                        fpStart = flatpickr('#guestStartDate', {
                            minDate: 'today',
                            dateFormat: 'Y-m-d',
                            locale: 'ru',
                            disable: disabledDates,   // ← теперь занятые даты передаются
                            static: true,
                            onChange: function(selectedDates, dateStr) {
                                if (fpEnd) fpEnd.set('minDate', dateStr);
                                updatePrice();
                            }
                        });

                        fpEnd = flatpickr('#guestEndDate', {
                            minDate: new Date().fp_incr(1),
                            dateFormat: 'Y-m-d',
                            locale: 'ru',
                            disable: disabledDates,   // ← и здесь
                            static: true,
                            onChange: updatePrice
                        });

                        // Устанавливаем даты по умолчанию
                        const today = new Date();
                        const tomorrow = new Date(today);
                        tomorrow.setDate(tomorrow.getDate() + 1);
                        fpStart.setDate(today);
                        fpEnd.setDate(tomorrow);

                        startInput.placeholder = 'Выберите дату';
                        endInput.placeholder = 'Выберите дату';
                        updatePrice();
                    })
                    .catch(err => {
                        console.error(err);
                        startInput.placeholder = 'Ошибка загрузки';
                        endInput.placeholder = 'Ошибка загрузки';
                        alert('Не удалось загрузить занятые даты. Попробуйте позже.');
                    });

                // Сброс формы
                form.reset();
                if (agreeCheck) agreeCheck.checked = false;
                if (submitBtn) submitBtn.disabled = true;
                if (deliveryOptions) deliveryOptions.style.display = 'none';
            });

            modalElement.addEventListener('hidden.bs.modal', destroyFlatpickr);

            if (agreeCheck) {
                agreeCheck.addEventListener('change', function() {
                    submitBtn.disabled = !this.checked;
                });
            }

            function updatePrice() {
                if (!startInput.value || !endInput.value) return;
                const start = new Date(startInput.value);
                const end = new Date(endInput.value);
                start.setHours(0,0,0,0);
                end.setHours(0,0,0,0);
                if (isNaN(start) || isNaN(end)) return;

                let days = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
                days = Math.max(1, days);

                let rate = pricePerDay;
                if (days >= 30 && pricePerDay30 > 0) rate = pricePerDay30;
                else if (days >= 15 && pricePerDay15 > 0) rate = pricePerDay15;

                let basePrice = rate * days;
                let deliveryPrice = 0;
                if (needDelivery && needDelivery.checked && deliveryLocation && deliveryLocation.value) {
                    const prices = { 'Sheremetyevo': 4500, 'Vnukovo': 3500, 'Domodedovo': 6000, 'Moscow': 0 };
                    deliveryPrice = prices[deliveryLocation.value] || 0;
                }
                const unlimitedPrice = unlimitedMileage && unlimitedMileage.checked ? unlimitedPricePerDay * days : 0;
                const rentTotal = basePrice + deliveryPrice + unlimitedPrice;
                const totalWithDeposit = rentTotal + deposit;
                const totalMileage = mileageLimit * days;

                rentalPeriodEl.textContent = days + ' ' + getDaysWord(days);
                totalPriceEl.textContent = formatCurrency(rentTotal);

                let breakdown = `${formatCurrency(rate)} × ${days} ${getDaysWord(days)}`;
                if (deliveryPrice > 0) breakdown += ` + доставка ${formatCurrency(deliveryPrice)}`;
                if (unlimitedPrice > 0) breakdown += ` + безлимит ${formatCurrency(unlimitedPrice)}`;
                breakdown += ` = ${formatCurrency(rentTotal)}`;
                breakdown += `<br><strong>Включённый пробег: ${mileageLimit} км/сут × ${days} сут = ${totalMileage} км</strong>`;
                breakdown += `<br><strong>Стоимость перепробега: ${formatCurrency(overMileagePricePerKm)}/км (оплачивается отдельно при превышении лимита ${mileageLimit} км/сут)</strong>`;
                breakdown += `<br><span class="text-warning">➕ Залог (возвратный): ${formatCurrency(deposit)}</span>`;
                breakdown += `<br><strong>Итого к блокировке: ${formatCurrency(totalWithDeposit)}</strong>`;
                priceBreakdownEl.innerHTML = breakdown;
            }

            function formatCurrency(amount) {
                return new Intl.NumberFormat('ru-RU', { style: 'currency', currency: 'RUB', minimumFractionDigits: 0 }).format(amount);
            }
            function getDaysWord(d) {
                if (d % 10 === 1 && d % 100 !== 11) return 'день';
                if (d % 10 >= 2 && d % 10 <= 4 && (d % 100 < 10 || d % 100 >= 20)) return 'дня';
                return 'дней';
            }

            if (needDelivery) {
                needDelivery.addEventListener('change', function() {
                    deliveryOptions.style.display = this.checked ? 'block' : 'none';
                    if (!this.checked) deliveryLocation.value = '';
                    updatePrice();
                });
            }
            if (deliveryLocation) deliveryLocation.addEventListener('change', updatePrice);
            if (unlimitedMileage) unlimitedMileage.addEventListener('change', updatePrice);

            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                if (!agreeCheck || !agreeCheck.checked) {
                    alert('Необходимо согласиться с условиями оферты');
                    return;
                }

                const payload = {
                    carId: document.getElementById('guestCarId').value,
                    startDate: startInput.value,
                    endDate: endInput.value,
                    name: document.getElementById('guestFullName').value,
                    phone: document.getElementById('guestPhone').value,
                    email: document.getElementById('guestEmail').value,
                    unlimitedMileage: unlimitedMileage?.checked ?? false,
                    deliveryLocation: deliveryLocation?.value || null
                };

                const originalText = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Отправка...';

                try {
                    const response = await fetch('/Booking/QuickBook', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(payload)
                    });
                    const result = await response.json();
                    if (result.success) {
                        bootstrap.Modal.getInstance(modalElement).hide();
                        alert('✅ ' + result.message);
                    } else {
                        alert('❌ Ошибка: ' + (result.message || (result.errors ? result.errors.join(', ') : 'Неизвестная ошибка')));
                    }
                } catch (err) {
                    console.error(err);
                    alert('Ошибка сети. Попробуйте позже.');
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                }
            });
        })();
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const modalElement = document.getElementById('bookingModal');
            if (!modalElement) return;
            
            let bookingModal = null;
            let fpStart = null, fpEnd = null;
            const pricePerDay = @pricePerDayJs;
            const pricePerDay15 = @pricePerDay15Js;
            const pricePerDay30 = @pricePerDay30Js;
            const deposit = @depositJs;
            const unlimitedPricePerDay = @unlimitedMileagePriceJs;
            const overMileagePricePerKm = @overMileagePriceJs;   // Добавлено для возможного использования
            const mileageLimit = @mileageLimitJs;
            
            const startInput = document.getElementById('StartDate');
            const endInput = document.getElementById('EndDate');
            const needDelivery = document.getElementById('needDelivery');
            const deliveryOptions = document.getElementById('deliveryOptions');
            const deliveryLocation = document.getElementById('deliveryLocation');
            const unlimitedMileage = document.getElementById('unlimitedMileage');
            const rentalPeriodEl = document.getElementById('rentalPeriod');
            const totalPriceEl = document.getElementById('totalPrice');
            const priceBreakdownEl = document.getElementById('priceBreakdown');
            const agreeCheck = document.getElementById('agreeTerms');
            const submitBtn = document.getElementById('submitBtn');
            
            if (!startInput || !endInput) return;

            // Функция очистки календарей
            function destroyFlatpickr() {
                if (fpStart) { fpStart.destroy(); fpStart = null; }
                if (fpEnd) { fpEnd.destroy(); fpEnd = null; }
            }

            // Функция очистки backdrop'ов
            function removeBackdrops() {
                document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
                document.body.classList.remove('modal-open');
                document.body.style.overflow = '';
                document.body.style.paddingRight = '';
            }

            // Инициализация при открытии модального окна
            modalElement.addEventListener('show.bs.modal', function() {
                destroyFlatpickr();
                
                const form = document.getElementById('bookingForm');
                if (form) form.reset();
                if (deliveryOptions) deliveryOptions.style.display = 'none';
                if (agreeCheck) agreeCheck.checked = false;
                if (submitBtn) submitBtn.disabled = true;
                
                startInput.placeholder = "Загрузка...";
                endInput.placeholder = "Загрузка...";
                
                fetch('/api/bookings/occupied-dates?carId=@car?.Id')
                    .then(r => r.ok ? r.json() : Promise.reject('Ошибка сервера'))
                    .then(disabledDates => {
                        fpStart = flatpickr(startInput, {
                            minDate: "today",
                            dateFormat: "Y-m-d",
                            locale: "ru",
                            disable: disabledDates,
                            static: true,
                            onChange: function(selectedDates, dateStr) {
                                if (fpEnd) fpEnd.set('minDate', dateStr);
                                updatePrice();
                            }
                        });
                        
                        fpEnd = flatpickr(endInput, {
                            minDate: new Date().fp_incr(1),
                            dateFormat: "Y-m-d",
                            locale: "ru",
                            disable: disabledDates,
                            static: true,
                            onChange: updatePrice
                        });
                        
                        const today = new Date();
                        const tomorrow = new Date(today);
                        tomorrow.setDate(tomorrow.getDate() + 1);
                        fpStart.setDate(today);
                        fpEnd.setDate(tomorrow);
                        
                        startInput.placeholder = "Выберите дату";
                        endInput.placeholder = "Выберите дату";
                        updatePrice();
                    })
                    .catch(err => {
                        console.error(err);
                        startInput.placeholder = "Ошибка загрузки";
                        endInput.placeholder = "Ошибка загрузки";
                        alert('Не удалось загрузить занятые даты. Попробуйте позже.');
                    });
            });
            
            // При скрытии модального окна
            modalElement.addEventListener('hidden.bs.modal', function() {
                destroyFlatpickr();
                removeBackdrops();
            });

            // При закрытии через ESC или клик на backdrop также очищаем
            modalElement.addEventListener('hide.bs.modal', function() {
                destroyFlatpickr();
            });

            bookingModal = new bootstrap.Modal(modalElement);
            
            if (agreeCheck) {
                agreeCheck.addEventListener('change', function() {
                    if (submitBtn) submitBtn.disabled = !this.checked;
                });
            }

            function updatePrice() {
                if (!startInput.value || !endInput.value) return;
                
                // Нормализация дат (убираем влияние часовых поясов)
                const start = new Date(startInput.value);
                const end = new Date(endInput.value);
                start.setHours(0, 0, 0, 0);
                end.setHours(0, 0, 0, 0);
                
                if (isNaN(start) || isNaN(end)) return;
                
                let days = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
                days = Math.max(1, days);
                
                // Выбор тарифа с проверкой на валидность (>0)
                let rate = pricePerDay;
                if (days >= 30 && pricePerDay30 > 0) {
                    rate = pricePerDay30;
                } else if (days >= 15 && pricePerDay15 > 0) {
                    rate = pricePerDay15;
                } else if (pricePerDay <= 0) {
                    console.error('Цена за день не задана');
                    rate = 0;
                }
                
                let basePrice = rate * days;
                
                // Доставка
                let deliveryPrice = 0;
                if (needDelivery && needDelivery.checked && deliveryLocation && deliveryLocation.value) {
                    const prices = { 'Sheremetyevo': 4500, 'Vnukovo': 3500, 'Domodedovo': 6000, 'Moscow': 0 };
                    deliveryPrice = prices[deliveryLocation.value] || 0;
                }
                
                // Безлимитный пробег
                const unlimitedPrice = unlimitedMileage && unlimitedMileage.checked ? unlimitedPricePerDay * days : 0;
                
                // ИТОГО за аренду (без депозита)
                const rentTotal = basePrice + deliveryPrice + unlimitedPrice;
                // С депозитом (для информации)
                const totalWithDeposit = rentTotal + deposit;
                const totalMileage = mileageLimit * days;
                
                // Вывод в UI
                rentalPeriodEl.textContent = days + ' ' + getDaysWord(days);
                totalPriceEl.textContent = formatCurrency(rentTotal);   // ← без депозита
                
                // Детализация: показываем и залог отдельно
                let breakdown = `${formatCurrency(rate)} × ${days} ${getDaysWord(days)}`;
                if (deliveryPrice > 0) breakdown += ` + доставка ${formatCurrency(deliveryPrice)}`;
                if (unlimitedPrice > 0) breakdown += ` + безлимит ${formatCurrency(unlimitedPrice)}`;
                breakdown += ` = ${formatCurrency(rentTotal)}`;

                
                breakdown += `<br><strong>Включённый пробег: ${mileageLimit} км/сут × ${days} сут = ${totalMileage} км</strong>`;
                breakdown += `<br><strong>Стоимость перепробега: ${formatCurrency(overMileagePricePerKm)}/км (оплачивается отдельно при превышении лимита ${mileageLimit} км/сут)</strong>`;
                breakdown += `<br><span class="text-warning">➕ Залог (возвратный): ${formatCurrency(deposit)}</span>`;
                breakdown += `<br><strong>Итого к блокировке: ${formatCurrency(totalWithDeposit)}</strong>`;
                priceBreakdownEl.innerHTML = breakdown;
            }
            
            function formatCurrency(amount) {
                return new Intl.NumberFormat('ru-RU', { style: 'currency', currency: 'RUB', minimumFractionDigits: 0 }).format(amount);
            }
            function getDaysWord(d) {
                if (d % 10 === 1 && d % 100 !== 11) return 'день';
                if (d % 10 >= 2 && d % 10 <= 4 && (d % 100 < 10 || d % 100 >= 20)) return 'дня';
                return 'дней';
            }
            
            if (needDelivery) {
                needDelivery.addEventListener('change', function() {
                    deliveryOptions.style.display = this.checked ? 'block' : 'none';
                    if (!this.checked) deliveryLocation.value = '';
                    updatePrice();
                });
            }
            if (deliveryLocation) deliveryLocation.addEventListener('change', updatePrice);
            if (unlimitedMileage) unlimitedMileage.addEventListener('change', updatePrice);
            
            const form = document.getElementById('bookingForm');
            if (form) {
                form.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    if (!agreeCheck || !agreeCheck.checked) {
                        alert('Необходимо согласиться с условиями оферты');
                        return;
                    }
                    const originalText = submitBtn.innerHTML;
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Обработка...';
                    submitBtn.disabled = true;
                    
                    try {
                        const formData = new FormData(form);
                        const response = await fetch(form.action, {
                            method: 'POST',
                            body: formData,
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        const result = await response.json();
                        if (result.success) {
                            bookingModal.hide();
                            setTimeout(() => { if (result.redirectUrl) window.location.href = result.redirectUrl; }, 1000);
                        } else {
                            alert(result.message || 'Ошибка бронирования');
                            submitBtn.innerHTML = originalText;
                            submitBtn.disabled = false;
                        }
                    } catch (error) {
                        alert('Ошибка сети');
                        submitBtn.innerHTML = originalText;
                        submitBtn.disabled = false;
                    }
                });
            }
            
            document.getElementById('cancelBtn')?.addEventListener('click', () => bookingModal.hide());
        });
        
        
    </script>
}