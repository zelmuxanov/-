@using CarRental.BLL.DTOs.Car
@using System.Web
@using CarRental.Domain.Enums
@using CarRental.BLL.Interfaces.Services
@model (CarRental.BLL.DTOs.Car.CarDto Car, CarRental.Web.ViewModels.Car.BookCarViewModel? BookingModel)
@inject ISiteSettingsService SiteSettings

@{
    ViewData["Title"] = $"{Model.Car?.Brand} {Model.Car?.Model}";
    Layout = "_Layout";
    
    var car = Model.Car;
    var bookingModel = Model.BookingModel;
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var settings = SiteSettings.GetSettings();

    var pricePerDay = Model.Car?.PricePerDay ?? 0;
    var pricePerDayJs = pricePerDay.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

    var pricePerDay15 = car?.PricePerDay15 ?? 0;
    var pricePerDay15Js = pricePerDay15.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

    var pricePerDay30 = car?.PricePerDay30 ?? 0;
    var pricePerDay30Js = pricePerDay30.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

    var depositAmount = car?.Deposit ?? 0;
    var depositJs = depositAmount.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

    var unlimitedMileagePrice = car?.UnlimitedMileagePrice > 0 ? car.UnlimitedMileagePrice : 2000;
    var unlimitedMileagePriceJs = unlimitedMileagePrice.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

    // ИСПРАВЛЕНО: теперь overMileagePriceJs использует правильную переменную overMileagePrice
    var overMileagePrice = car?.OverMileagePricePerKm > 0 ? car.OverMileagePricePerKm : 2000;
    var overMileagePriceJs = overMileagePrice.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

    var mileageLimit = car?.MileageLimitPerDay ?? 250;
    var mileageLimitJs = mileageLimit.ToString(System.Globalization.CultureInfo.InvariantCulture);
    
    var images = car?.Images != null 
        ? car.Images.OrderBy(i => i.DisplayOrder).ToList() 
        : new List<CarImageDto>();
    var mainImage = images.FirstOrDefault(i => i.IsMain) ?? images.FirstOrDefault();
}

<div class="car-details-container">
    <script type="application/ld+json">
        {       
        "@@context": "https://schema.org",
        "@@type": "Car",
        "name": "@Model.Car?.Brand @Model.Car?.Model",
        "description": "@HttpUtility.JavaScriptStringEncode(Model.Car?.Description ?? "")",
        "modelDate": "@Model.Car?.Year",
        "image": "@($"{Context.Request.Scheme}://{Context.Request.Host}{Model.Car?.MainImageUrl}")",
        "offers": {
            "@@type": "Offer",
            "price": "@Model.Car?.PricePerDay",
            "priceCurrency": "RUB",
            "availability": "@(Model.Car?.IsAvailable == true ? "https://schema.org/InStock" : "https://schema.org/OutOfStock")",
            "url": "@($"{Context.Request.Scheme}://{Context.Request.Host}{Url.Action("Details", "Car", new { id = Model.Car?.Id })}")"
            }
        }
    </script>
    <!-- Hero Section с каруселью -->
    <div class="car-details-hero">
        @if (images.Any())
        {
            <div id="carCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        <button type="button" data-bs-target="#carCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-label="Слайд @(i+1)"></button>
                    }
                </div>
                <div class="carousel-inner">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        var img = images[i];
                        <div class="carousel-item @(i == 0 ? "active" : "")">                            
                            <img src="@img.ImageUrl" class="d-block w-100" alt="@car?.Brand @car?.Model" style="height:500px; object-fit:contain; background:#1a1e24;">                            
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Предыдущий</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Следующий</span>
                </button>
            </div>
            @if (images.Count > 1)
            {
                <div class="thumbnail-row d-flex gap-2 flex-wrap mt-3 justify-content-center">
                    @foreach (var img in images)
                    {
                        <div class="thumbnail-item" data-bs-target="#carCarousel" data-bs-slide-to="@images.IndexOf(img)" style="cursor:pointer;">
                            <img src="@img.ImageUrl" class="thumbnail-img" alt="Миниатюра" style="width:80px; height:60px; object-fit:cover; border-radius:6px; border:2px solid transparent;">
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="car-details-image bg-secondary d-flex align-items-center justify-content-center" style="height:500px;">
                <i class="fas fa-car fa-6x text-muted"></i>
            </div>
        }
        
        <div class="car-details-overlay">
            <div class="container-xxl">
                <h1 class="car-details-title">@car?.Brand @car?.Model</h1>
                <p class="car-details-subtitle">
                    @GetCarClassDisplay(car?.Class ?? CarClass.Standard) • @car?.Year год • @GetTransmissionDisplay(car?.Transmission ?? TransmissionType.Automatic)
                </p>
            </div>
        </div>
    </div>
    
    <div class="container-xxl">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="car-specs-grid">
                    <div class="car-spec-card hover-lift">
                        <div class="car-spec-icon"><i class="fas fa-gas-pump"></i></div>
                        <div class="car-spec-value">@GetFuelTypeDisplay(car?.FuelType ?? FuelType.Petrol)</div>
                        <div class="car-spec-label">Тип топлива</div>
                    </div>
                    <div class="car-spec-card hover-lift">
                        <div class="car-spec-icon"><i class="fas fa-cogs"></i></div>
                        <div class="car-spec-value">@GetTransmissionDisplay(car?.Transmission ?? TransmissionType.Automatic)</div>
                        <div class="car-spec-label">Коробка передач</div>
                    </div>
                    <div class="car-spec-card hover-lift">
                        <div class="car-spec-icon"><i class="fas fa-user-friends"></i></div>
                        <div class="car-spec-value">@car?.Seats мест</div>
                        <div class="car-spec-label">Вместимость</div>
                    </div>
                    <div class="car-spec-card hover-lift">
                        <div class="car-spec-icon"><i class="fas fa-tachometer-alt"></i></div>
                        <div class="car-spec-value">@car?.EngineCapacity л</div>
                        <div class="car-spec-label">Объем двигателя</div>
                    </div>
                    <div class="car-spec-card hover-lift">
                        <div class="car-spec-icon"><i class="fas fa-fas fa-road"></i></div>
                        <div class="car-spec-value">@car?.MileageLimitPerDay км</div>
                        <div class="car-spec-label">Ограничение по километражу/сут</div>
                    </div>
                    <div class="car-spec-card hover-lift">
                        <div class="car-spec-icon"><i class="fa fa-rub"></i></div>
                        <div class="car-spec-value">@car?.Deposit.ToString("N0") ₽</div>
                        <div class="car-spec-label">Сумма депозита</div>
                    </div>
                </div>
                
                @if (!string.IsNullOrEmpty(car?.Description))
                {
                    <div class="card-modern mb-4">
                        <div class="card-header-modern">
                            <h3 class="mb-0">Описание автомобиля</h3>
                        </div>
                        <div class="card-body-modern">
                            <p class="mb-0">@car.Description</p>
                        </div>
                    </div>
                }
                
                <!-- Детальные характеристики -->
                <div class="card-modern">
                    <div class="card-header-modern">
                        <h3 class="mb-0">Детальные характеристики</h3>
                    </div>
                    <div class="card-body-modern">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3"><strong>Бренд:</strong> @car?.Brand</div>
                                <div class="mb-3"><strong>Модель:</strong> @car?.Model</div>
                                <div class="mb-3"><strong>Класс:</strong> @GetCarClassDisplay(car?.Class ?? CarClass.Standard)</div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3"><strong>Цвет:</strong> @car?.Color</div>
                                <div class="mb-3"><strong>Объем двигателя:</strong> @car?.EngineCapacity л</div>
                                <div class="mb-3"><strong>Год выпуска:</strong> @car?.Year</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Ьаблица стоимости -->
                <div class="card-modern">
                    <div class="card-header-modern">
                        <h3 class="mb-0">Детали рассчета стоимости</h3>
                    </div>
                    <div class="card-body-modern">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3"><strong>Стоимость аренды:</strong> @car?.PricePerDay.ToString("N0") ₽/сут</div>
                                <div class="mb-3"><strong>Стоимость аренды от 15 сут:</strong> @car?.PricePerDay15.ToString("N0") ₽/сут</div>
                                <div class="mb-3"><strong>Стоимость аренды от 30 сут:</strong> @car?.PricePerDay30.ToString("N0") ₽/сут</div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3"><strong>Стоимость перепробега:</strong> @car?.OverMileagePricePerKm.ToString("N0") ₽/км</div>
                                <div class="mb-3"><strong>Ограничение по километражу:</strong> @car?.MileageLimitPerDay км</div>
                                <div class="mb-3"><strong>Сумма депозита:</strong> @car?.Deposit.ToString("N0") ₽</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Требования к арендатору  -->
                @if (settings.RenterRequirements != null && settings.RenterRequirements.Any())
                {
                    <div class="card-modern mt-4">
                        <div class="card-header-modern">
                            <h3 class="mb-0">Требования к арендатору</h3>
                        </div>
                        <div class="card-body-modern">
                            <ul class="list-unstyled mb-0">
                                @foreach (var req in settings.RenterRequirements)
                                {
                                    <li class="mb-2">
                                        <i class="fas fa-check-circle text-success me-2"></i>
                                        <strong>@req.Question</strong> — @req.ExpectedAnswer
                                    </li>
                                }
                            </ul>
                            <div class="alert alert-warning mt-3 mb-0 small">
                                <i class="fas fa-info-circle"></i> Пожалуйста, убедитесь, что вы соответствуете указанным требованиям перед бронированием.
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="col-lg-4">
                <div class="sticky-top" style="top: 6.5rem;">
                    <div class="card-modern mb-4">
                        <div class="card-body-modern">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div>
                                    <h4 class="mb-1">@car?.Brand @car?.Model</h4>
                                    <p class="text-muted mb-0">@car?.Class • @car?.Year</p>
                                </div>
                                <span class="badge @(car?.IsAvailable == true ? "bg-success" : "bg-danger")">
                                    @(car?.IsAvailable == true ? "Доступен" : "Занят")
                                </span>
                            </div>
                            
                            <div class="text-center mb-4">
                                <div class="car-price-modern">
                                    @car?.PricePerDay.ToString("C0")
                                    <span class="d-block text-sm">в сутки</span>
                                </div>
                            </div>
                            
                            @if (isAuthenticated && car?.IsAvailable == true)
                            {
                                <button class="btn-primary-modern btn-modern w-100 mb-3" data-bs-toggle="modal" data-bs-target="#bookingModal">
                                    <i class="fas fa-calendar-check me-2"></i> Забронировать сейчас
                                </button>
                            }
                            else if (!isAuthenticated && car?.IsAvailable == true)
                            {
                                <button class="btn-primary-modern btn-modern w-100 mb-2" data-bs-toggle="modal" data-bs-target="#guestBookingModal">
                                    <i class="fas fa-calendar-check me-2"></i> Забронировать
                                </button>
                                <div class="text-center text-muted small mb-3">
                                    <i class="fas fa-info-circle me-1"></i> 
                                    <a href="/Account/Login?returnUrl=@Url.Action("Details", "Car", new { id = car?.Id })" class="text-muted">Войдите</a> или 
                                    <a href="/Account/Register?returnUrl=@Url.Action("Details", "Car", new { id = car?.Id })" class="text-muted">зарегистрируйтесь</a> для более быстрого бронирования.
                                </div>
                            }
                            else if (car?.IsAvailable == false)
                            {
                                <div class="alert alert-warning mb-3">
                                    <p class="mb-0">Этот автомобиль в настоящее время недоступен для бронирования</p>
                                </div>
                            }
                            
                            <a href="/Car" class="btn-outline-modern btn-modern w-100">
                                <i class="fas fa-arrow-left me-2"></i> Назад к каталогу
                            </a>
                        </div>
                    </div>
                    <div class="card-modern">
                        <div class="card-header-modern">
                            <h5 class="mb-0">Контакты</h5>
                        </div>
                        <div class="card-body-modern">
                            <div class="d-flex align-items-center mb-3">
                                <i class="fas fa-phone text-primary me-3"></i>
                                <div><small class="text-muted d-block">Телефон</small><strong>@settings.Phone</strong></div>
                            </div>
                            <div class="d-flex align-items-center mb-3">
                                <i class="fas fa-envelope text-primary me-3"></i>
                                <div><small class="text-muted d-block">Email</small><strong>@settings.Email</strong></div>
                            </div>
                            <div class="d-flex align-items-center mb-3">
                                <i class="fas fa-clock text-primary me-3"></i>
                                <div><small class="text-muted d-block">Режим работы</small><strong>10:00 - 20:00</strong></div>
                            </div>
                            <hr>
                            <div class="text-center">
                                <small class="text-muted d-block mb-2">Свяжитесь с нами в мессенджерах</small>
                                <div class="d-flex justify-content-center gap-3">
                                    @if (!string.IsNullOrEmpty(settings.WhatsAppUrl))
                                    {
                                        <a href="@settings.WhatsAppUrl" class="btn btn-sm btn-outline-success" target="_blank" rel="noopener" title="WhatsApp">
                                            <i class="fab fa-whatsapp me-1"></i> WhatsApp
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(settings.TelegramUrl))
                                    {
                                        <a href="@settings.TelegramUrl" class="btn btn-sm btn-outline-info" target="_blank" rel="noopener" title="Telegram">
                                            <i class="fab fa-telegram me-1"></i> Telegram
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(settings.MaxUrl))
                                    {
                                        <a href="@settings.MaxUrl" class="btn btn-sm btn-outline-primary" target="_blank" rel="noopener" title="Messenger MAX">
                                            <span class="max-logo-icon" style="margin-right: 4px;"></span> MAX
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetCarClassDisplay(CarClass carClass) => carClass switch
    {
        CarClass.Standard => "Стандарт",
        CarClass.SUV => "Кроссовер",
        CarClass.Business => "Бизнес",
        CarClass.Minivan => "Минивэн",
        _ => carClass.ToString()
    };
    
    string GetFuelTypeDisplay(FuelType fuelType) => fuelType switch
    {
        FuelType.Petrol => "Бензин",
        FuelType.Diesel => "Дизель",
        FuelType.Hybrid => "Гибрид",
        _ => fuelType.ToString()
    };
    
    string GetTransmissionDisplay(TransmissionType transmission) => transmission switch
    {
        TransmissionType.Manual => "Механика",
        TransmissionType.Automatic => "Автомат",
        _ => transmission.ToString()
    };
}

<!-- Модальное окно бронирования -->
@if (isAuthenticated && bookingModel != null && car?.IsAvailable == true)
{
    <div class="modal fade" id="bookingModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0" style="background: #111827; color: #fff; border-radius: 12px; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);">
                <div class="modal-header border-bottom border-gray-800 px-4 py-3" style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.8) 100%); backdrop-filter: blur(10px);">
                    <div class="flex-grow-1">
                        <h5 class="modal-title fw-semibold text-white mb-0">Бронирование автомобиля</h5>
                        <p class="text-gray-400 mb-0 small mt-1">@car?.Brand @car?.Model</p>
                    </div>
                    <button type="button" class="btn-close btn-close-white opacity-70" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                <div class="modal-body p-4">
                    <form method="post" action="@Url.Action("BookCar", "Booking")" id="bookingForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CarId" value="@car?.Id" />
                        
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-white fw-medium mb-2">Дата начала</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-gray-900 border-gray-700 text-gray-300"><i class="fas fa-calendar-alt"></i></span>
                                    <input type="text" id="StartDate" name="StartDate" class="form-control bg-gray-900 border-gray-700 text-white" placeholder="Выберите дату" required />
                                </div>
                                <div class="form-text text-gray-500 mt-2 small">Доступно с сегодняшнего дня</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white fw-medium mb-2">Дата окончания</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-gray-900 border-gray-700 text-gray-300"><i class="fas fa-calendar-check"></i></span>
                                    <input type="text" id="EndDate" name="EndDate" class="form-control bg-gray-900 border-gray-700 text-white" placeholder="Выберите дату" required />
                                </div>
                                <div class="form-text text-gray-500 mt-2 small">Минимальный срок — от 1 дня</div>
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <h6 class="text-white fw-medium mb-3">Дополнительные услуги</h6>
                            <div class="form-check form-check-dark mb-3">
                                <input class="form-check-input" type="checkbox" id="needDelivery" name="NeedDelivery" value="true">
                                <label class="form-check-label text-white d-flex align-items-center" for="needDelivery">
                                    <span class="icon-wrapper me-3"><i class="fas fa-truck text-gray-400"></i></span>
                                    <span><span class="d-block fw-normal">Доставка автомобиля</span><small class="text-gray-500">Доставка к указанному месту</small></span>
                                </label>
                            </div>
                            <div class="ps-4 mb-3" id="deliveryOptions" style="display: none;">
                                <select name="DeliveryLocation" class="form-select bg-gray-900 border-gray-700 text-white" id="deliveryLocation">
                                    <option value="">Выберите место доставки</option>
                                    <option value="Sheremetyevo">Шереметьево (+4 500 ₽)</option>
                                    <option value="Vnukovo">Внуково (+3 500 ₽)</option>
                                    <option value="Domodedovo">Домодедово (+6 000 ₽)</option>
                                    <option value="Moscow">По Москве (индивидуально)</option>
                                </select>
                            </div>
                            <div class="form-check form-check-dark">
                                <input class="form-check-input" type="checkbox" id="unlimitedMileage" name="UnlimitedMileage" value="true">
                                <label class="form-check-label text-white d-flex align-items-center" for="unlimitedMileage">
                                    <span class="icon-wrapper me-3"><i class="fas fa-infinity text-gray-400"></i></span>
                                    <span><span class="d-block fw-normal">Безлимитный пробег</span><small class="text-gray-500">@car?.UnlimitedMileagePrice.ToString("N0") ₽ за каждые сутки аренды</small></span>
                                </label>
                            </div>
                        </div>
                        
                        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div><div class="text-gray-400 small mb-1">Период аренды</div><div class="text-white fw-medium" id="rentalPeriod">—</div></div>
                                <div class="text-end"><div class="text-gray-400 small mb-1">Общая стоимость</div><div class="text-white h4 mb-0 fw-semibold" id="totalPrice">—</div></div>
                            </div>
                            <div class="text-gray-500 small" id="priceBreakdown"></div>
                        </div>
                        
                        <div class="alert alert-info mt-3" style="background: #1e293b; border-color: #334155; color: #bae6fd;">
                            <i class="fas fa-shield-alt me-2"></i>
                            <strong>Обеспечительный платёж @car?.Deposit.ToString("N0") ₽</strong> будет временно заблокирован на вашей карте.
                            <a href="/Home/FAQ#deposit" target="_blank" style="color: #7dd3fc;">Подробнее в FAQ</a>
                        </div>

                        <!-- Чекбокс согласия с офертой -->
                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" id="agreeTerms" name="AgreeTerms" required>
                            <label class="form-check-label text-white" for="agreeTerms">
                                Я согласен с <a href="/Home/Terms" target="_blank" style="color: #7dd3fc;">условиями оферты</a>
                            </label>
                        </div>
                        
                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn btn-primary flex-grow-1 py-3 fw-semibold" id="submitBtn" style="background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); border: none;">
                                <i class="fas fa-check-circle me-2"></i>Подтвердить бронирование
                            </button>
                            <button type="button" class="btn btn-outline-light border-gray-700 text-white px-4 py-3" data-bs-dismiss="modal">Отмена</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
@if (!isAuthenticated && car?.IsAvailable == true)
{
    <div class="modal fade" id="guestBookingModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0" style="background: #111827; color: #fff; border-radius: 12px; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);">
                <div class="modal-header border-bottom border-gray-800 px-4 py-3" style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.8) 100%); backdrop-filter: blur(10px);">
                    <div class="flex-grow-1">
                        <h5 class="modal-title fw-semibold text-white mb-0">Бронирование автомобиля</h5>
                        <p class="text-gray-400 mb-0 small mt-1">@car?.Brand @car?.Model</p>
                    </div>
                    <button type="button" class="btn-close btn-close-white opacity-70" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                <div class="modal-body p-4">
                    <form id="guestBookingForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="guestCarId" name="CarId" value="@car?.Id" />
                        
                        <!-- Контактные данные -->
                        <h6 class="text-white fw-medium mb-3">Ваши данные</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-white fw-medium mb-2">ФИО *</label>
                                <input type="text" id="guestFullName" name="FullName" class="form-control bg-gray-900 border-gray-700 text-white" placeholder="Иванов Иван Иванович" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white fw-medium mb-2">Телефон *</label>
                                <input type="tel" id="guestPhone" name="Phone" class="form-control bg-gray-900 border-gray-700 text-white" placeholder="+7 (___) ___-__-__" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white fw-medium mb-2">Email *</label>
                                <input type="email" id="guestEmail" name="Email" class="form-control bg-gray-900 border-gray-700 text-white" placeholder="email@example.com" required>
                            </div>
                        </div>
                        
                        <!-- Даты аренды -->
                        <h6 class="text-white fw-medium mb-3">Даты аренды</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-white fw-medium mb-2">Дата начала</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-gray-900 border-gray-700 text-gray-300"><i class="fas fa-calendar-alt"></i></span>
                                    <input type="text" id="guestStartDate" name="StartDate" class="form-control bg-gray-900 border-gray-700 text-white" placeholder="Выберите дату" required />
                                </div>
                                <div class="form-text text-gray-500 mt-2 small">Доступно с сегодняшнего дня</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white fw-medium mb-2">Дата окончания</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-gray-900 border-gray-700 text-gray-300"><i class="fas fa-calendar-check"></i></span>
                                    <input type="text" id="guestEndDate" name="EndDate" class="form-control bg-gray-900 border-gray-700 text-white" placeholder="Выберите дату" required />
                                </div>
                                <div class="form-text text-gray-500 mt-2 small">Минимальный срок — от 1 дня</div>
                            </div>
                        </div>
                        
                        <!-- Дополнительные услуги -->
                        <h6 class="text-white fw-medium mb-3">Дополнительные услуги</h6>
                        <div class="mb-4">
                            <div class="form-check form-check-dark mb-3">
                                <input class="form-check-input" type="checkbox" id="guestNeedDelivery" name="NeedDelivery" value="true">
                                <label class="form-check-label text-white d-flex align-items-center" for="guestNeedDelivery">
                                    <span class="icon-wrapper me-3"><i class="fas fa-truck text-gray-400"></i></span>
                                    <span><span class="d-block fw-normal">Доставка автомобиля</span><small class="text-gray-500">Доставка к указанному месту</small></span>
                                </label>
                            </div>
                            <div class="ps-4 mb-3" id="guestDeliveryOptions" style="display: none;">
                                <select name="DeliveryLocation" class="form-select bg-gray-900 border-gray-700 text-white" id="guestDeliveryLocation">
                                    <option value="">Выберите место доставки</option>
                                    <option value="Sheremetyevo">Шереметьево (+4 500 ₽)</option>
                                    <option value="Vnukovo">Внуково (+3 500 ₽)</option>
                                    <option value="Domodedovo">Домодедово (+6 000 ₽)</option>
                                    <option value="Moscow">По Москве (индивидуально)</option>
                                </select>
                            </div>
                            <div class="form-check form-check-dark">
                                <input class="form-check-input" type="checkbox" id="guestUnlimitedMileage" name="UnlimitedMileage" value="true">
                                <label class="form-check-label text-white d-flex align-items-center" for="guestUnlimitedMileage">
                                    <span class="icon-wrapper me-3"><i class="fas fa-infinity text-gray-400"></i></span>
                                    <span><span class="d-block fw-normal">Безлимитный пробег</span><small class="text-gray-500">@car?.UnlimitedMileagePrice.ToString("N0") ₽ за каждые сутки аренды</small></span>
                                </label>
                            </div>
                        </div>
                        
                        <!-- Расчёт стоимости -->
                        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div><div class="text-gray-400 small mb-1">Период аренды</div><div class="text-white fw-medium" id="guestRentalPeriod">—</div></div>
                                <div class="text-end"><div class="text-gray-400 small mb-1">Общая стоимость</div><div class="text-white h4 mb-0 fw-semibold" id="guestTotalPrice">—</div></div>
                            </div>
                            <div class="text-gray-500 small" id="guestPriceBreakdown"></div>
                        </div>
                        
                        <!-- Депозит -->
                        <div class="alert alert-info mt-3" style="background: #1e293b; border-color: #334155; color: #bae6fd;">
                            <i class="fas fa-shield-alt me-2"></i>
                            <strong>Обеспечительный платёж @car?.Deposit.ToString("N0") ₽</strong> будет временно заблокирован на вашей карте.
                            <a href="/Home/FAQ#deposit" target="_blank" style="color: #7dd3fc;">Подробнее в FAQ</a>
                        </div>

                        <!-- Чекбокс согласия с офертой -->
                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" id="guestAgreeTerms" name="AgreeTerms" required>
                            <label class="form-check-label text-white" for="guestAgreeTerms">
                                Я согласен с <a href="/Home/Terms" target="_blank" style="color: #7dd3fc;">условиями оферты</a>
                            </label>
                        </div>
                        
                        <!-- Кнопки -->
                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn btn-primary flex-grow-1 py-3 fw-semibold" id="guestSubmitBtn" style="background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); border: none;" disabled>
                                <i class="fas fa-check-circle me-2"></i>Отправить заявку
                            </button>
                            <button type="button" class="btn btn-outline-light border-gray-700 text-white px-4 py-3" data-bs-dismiss="modal">Отмена</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}


