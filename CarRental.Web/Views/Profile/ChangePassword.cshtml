@model CarRental.Web.ViewModels.Profile.ChangePasswordViewModel
@{
    ViewData["Title"] = "Смена пароля";
    Layout = "_Layout";
}

<div class="container-xxl py-4">
    <div class="row">
        <!-- Боковая навигация -->
        <div class="col-lg-3">
            <div class="profile-sidebar">
                <div class="profile-sidebar-header p-3 border-bottom">
                    <h6 class="mb-0" style="color: var(--text-primary);">Навигация</h6>
                </div>
                <div class="profile-sidebar-body">
                    <a href="@Url.Action("Index", "Profile")" 
                       class="profile-nav-item-modern @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="fas fa-home profile-nav-icon"></i><span>Обзор</span>
                    </a>
                    <a href="@Url.Action("Edit", "Profile")" 
                       class="profile-nav-item-modern @(ViewContext.RouteData.Values["Action"]?.ToString() == "Edit" ? "active" : "")">
                        <i class="fas fa-user-edit profile-nav-icon"></i><span>Редактировать профиль</span>
                    </a>
                    <a href="@Url.Action("Index", "Documents")" 
                        class="profile-nav-item-modern @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Documents" ? "active" : "")">
                        <i class="fas fa-file-contract profile-nav-icon"></i><span>Документы</span>
                    </a>
                    <a href="@Url.Action("Bookings", "Profile")" 
                       class="profile-nav-item-modern @(ViewContext.RouteData.Values["Action"]?.ToString() == "Bookings" ? "active" : "")">
                        <i class="fas fa-calendar profile-nav-icon"></i><span>Мои бронирования</span>
                    </a>
                    <a href="@Url.Action("ChangePassword", "Profile")" 
                       class="profile-nav-item-modern @(ViewContext.RouteData.Values["Action"]?.ToString() == "ChangePassword" ? "active" : "")">
                        <i class="fas fa-lock profile-nav-icon"></i><span>Смена пароля</span>
                    </a>
                    <a href="/Car" class="profile-nav-item-modern">
                        <i class="fas fa-search profile-nav-icon"></i><span>Найти автомобиль</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Основной контент -->
        <div class="col-lg-9">
            <div class="card-modern">
                <div class="card-header-modern">
                    <h2 class="mb-0">🔐 Смена пароля</h2>
                </div>
                <div class="card-body-modern">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label fw-bold">Текущий пароль *</label>
                            <input asp-for="CurrentPassword" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-bold">Новый пароль *</label>
                            <input asp-for="NewPassword" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold">Подтверждение *</label>
                            <input asp-for="ConfirmPassword" class="form-control" required />
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                            <button type="submit" class="btn btn-primary">Сменить пароль</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Валидация силы пароля
        document.getElementById('NewPassword')?.addEventListener('input', function() {
            const password = this.value;
            const strengthBar = document.getElementById('passwordStrengthBar');
            const strengthText = document.getElementById('passwordStrengthText');
            
            let strength = 0;
            let text = 'Слабый';
            let color = 'danger';
            
            if (password.length >= 6) strength += 25;
            if (password.match(/[a-z]/) && password.match(/[A-Z]/)) strength += 25;
            if (password.match(/\d/)) strength += 25;
            if (password.match(/[^a-zA-Z\d]/)) strength += 25;
            
            if (strength >= 75) {
                text = 'Сильный';
                color = 'success';
            } else if (strength >= 50) {
                text = 'Средний';
                color = 'warning';
            }
            
            if (strengthBar) {
                strengthBar.style.width = strength + '%';
                strengthBar.className = 'progress-bar bg-' + color;
            }
            if (strengthText) {
                strengthText.textContent = text + ' пароль';
                strengthText.className = 'text-' + color;
            }
        });

        // Подтверждение пароля
        document.getElementById('ConfirmPassword')?.addEventListener('input', function() {
            const newPassword = document.getElementById('NewPassword')?.value;
            const confirmPassword = this.value;
            
            if (confirmPassword && newPassword !== confirmPassword) {
                this.setCustomValidity('Пароли не совпадают');
            } else {
                this.setCustomValidity('');
            }
        });

        // Очистка валидации при загрузке
        document.addEventListener('DOMContentLoaded', function() {
            const confirmPassword = document.getElementById('ConfirmPassword');
            if (confirmPassword) {
                confirmPassword.setCustomValidity('');
            }
        });
    </script>
}