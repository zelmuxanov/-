@model CarRental.Web.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Восстановление пароля";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="bi bi-key me-2"></i>
                        Восстановление пароля
                    </h4>
                </div>
                
                <div class="card-body">
                    <p class="text-muted mb-4">
                        Введите ваш email. Мы отправим ссылку и код для восстановления пароля.
                    </p>
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <h5>Ошибки:</h5>
                            <ul class="mb-0">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }
                    
                    <form method="post" asp-controller="PasswordRecovery" asp-action="ForgotPassword">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label for="Email" class="form-label fw-bold">Email адрес *</label>
                            <input type="email" id="Email" name="Email" class="form-control" 
                                   value="@Model?.Email" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-send me-2"></i>
                                Получить код восстановления
                            </button>
                            
                            <a href="@Url.Action("Login", "Account")" 
                               class="btn btn-link text-decoration-none">
                                <i class="bi bi-arrow-left me-1"></i>
                                Вернуться к входу
                            </a>
                        </div>
                    </form>
                </div>
                
                <div class="card-footer text-muted text-center">
                    <small>
                        На вашу почту придет письмо со ссылкой и 6-значным кодом
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}