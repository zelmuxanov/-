@model CarRental.Web.ViewModels.Account.VerifyResetCodeViewModel
@{
    ViewData["Title"] = "Подтверждение сброса пароля";
    Layout = "~/Views/Shared/_SimpleLayout.cshtml";
    
    // Безопасное получение email из разных источников
    string email = string.Empty;
    
    // Сначала из ViewBag (динамический тип) с использованием правильного pattern matching
    if (ViewBag.Email is string viewBagEmail && !string.IsNullOrEmpty(viewBagEmail))
    {
        email = viewBagEmail;
    }
    
    // Затем из TempData
    if (string.IsNullOrEmpty(email))
    {
        var tempEmail = TempData["ResetEmail"] as string;
        if (!string.IsNullOrEmpty(tempEmail))
        {
            email = tempEmail;
        }
    }
    
    // Если email найден и модель не null, устанавливаем в модель
    if (!string.IsNullOrEmpty(email) && Model != null)
    {
        Model.Email = email;
    }
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-success">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-envelope-check me-2"></i>
                        Письмо отправлено
                    </h4>
                </div>
                
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="display-1 text-success mb-3">
                            <i class="bi bi-envelope-paper"></i>
                        </div>
                        <h2 class="text-success mb-3">Проверьте вашу почту</h2>
                    </div>
                    
                    <div class="alert alert-success" role="alert">
                        <h5 class="alert-heading">✅ Готово!</h5>
                        <p>
                            Мы отправили письмо на адрес <strong>@email</strong> с инструкциями 
                            по сбросу пароля.
                        </p>
                        <hr>
                        <p class="mb-0">
                            <strong>В письме вы найдете:</strong>
                            <ul class="mb-0">
                                <li>✅ Ссылку для сброса пароля (нажмите для перехода)</li>
                                <li>✅ 6-значный код подтверждения (введите ниже)</li>
                            </ul>
                        </p>
                    </div>
                    
                    <!-- Красивая форма для ввода кода -->
                    <div class="mt-5">
                        <h5 class="text-center mb-4">Введите 6-значный код из письма</h5>
                        
                        <form method="post" asp-action="VerifyResetCode" id="codeForm">
                            @Html.AntiForgeryToken()
                            
                            <!-- Скрытое поле для email -->
                            <input type="hidden" asp-for="Email" id="hiddenEmail" value="@email" />
                            
                            <!-- Отображение ошибок валидации -->
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger">
                                    <ul class="mb-0">
                                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                        {
                                            <li>@error.ErrorMessage</li>
                                        }
                                    </ul>
                                </div>
                            }
                            
                            <div class="mb-4">
                                <div class="d-flex justify-content-center gap-2 mb-3" id="codeInputContainer">
                                    @for (int i = 0; i < 6; i++)
                                    {
                                        <input type="text" 
                                               class="form-control text-center digit-input" 
                                               maxlength="1" 
                                               data-index="@i"
                                               style="width: 50px; height: 60px; font-size: 24px;"
                                               oninput="moveToNext(this, @i)"
                                               onkeydown="handleBackspace(this, event, @i)"
                                               autocomplete="off" />
                                    }
                                </div>
                                <input type="hidden" asp-for="Code" id="codeHidden" />
                                <span asp-validation-for="Code" class="text-danger small d-block text-center mt-2"></span>
                                <div class="form-text text-center">Введите 6 цифр из письма</div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success" id="submitButton" disabled>
                                    <i class="bi bi-check-circle me-2"></i>
                                    Подтвердить код
                                </button>
                                
                                <div class="text-center mt-3">
                                    <small class="text-muted">Или перейдите по ссылке из письма</small>
                                </div>
                                
                                <a href="@Url.Action("Login", "Account")" 
                                   class="btn btn-outline-secondary">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>
                                    Вернуться к входу
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
                
                <div class="card-footer text-muted text-center">
                    <small>
                        Не получили письмо? 
                        <a href="@Url.Action("ForgotPassword", "PasswordRecovery")">Отправить повторно</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Устанавливаем email в скрытое поле
            $('#hiddenEmail').val('@Html.Raw(email)');
            
            // Фокусируемся на первом поле
            $('.digit-input').first().focus();
            
            // Автоматически обновляем скрытое поле
            $('.digit-input').on('input', updateHiddenCode);
            
            function updateHiddenCode() {
                let code = '';
                $('.digit-input').each(function() {
                    code += $(this).val();
                });
                $('#codeHidden').val(code);
                
                // Активируем кнопку если все 6 цифр введены
                if (code.length === 6) {
                    $('#submitButton').prop('disabled', false);
                } else {
                    $('#submitButton').prop('disabled', true);
                }
            }
        });
        
        function moveToNext(input, index) {
            // Очищаем нецифровые символы
            input.value = input.value.replace(/[^0-9]/g, '');
            
            if (input.value.length === 1 && index < 5) {
                // Переходим к следующему полю
                const nextIndex = index + 1;
                const nextInput = document.querySelector(`.digit-input[data-index="${nextIndex}"]`);
                if (nextInput) {
                    nextInput.focus();
                    nextInput.select();
                }
            }
            
            // Обновляем скрытое поле
            updateHiddenField();
        }
        
        function handleBackspace(input, event, index) {
            if (event.key === 'Backspace' && input.value === '' && index > 0) {
                // Переходим к предыдущему полю
                const prevIndex = index - 1;
                const prevInput = document.querySelector(`.digit-input[data-index="${prevIndex}"]`);
                if (prevInput) {
                    prevInput.focus();
                    prevInput.select();
                }
            }
        }
        
        function updateHiddenField() {
            let code = '';
            document.querySelectorAll('.digit-input').forEach(input => {
                code += input.value;
            });
            document.getElementById('codeHidden').value = code;
            
            // Активируем/деактивируем кнопку
            const submitButton = document.getElementById('submitButton');
            if (submitButton) {
                submitButton.disabled = code.length !== 6;
            }
        }
    </script>
}