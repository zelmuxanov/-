                            <p class="text-gray-400 mb-0 small mt-1">Мы ответим в ближайшее время</p>
                        </div>
                        <button type="button" class="btn-close btn-close-white opacity-70" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-0">
                        <div id="chatMessages" style="height: 400px; overflow-y: auto; padding: 1rem;">
                            <div class="text-center text-muted py-5">
                                <i class="fas fa-spinner fa-spin fa-2x mb-3"></i>
                                <p>Загрузка чата...</p>
                            </div>
                        </div>
                        <div class="p-3 border-top">
                            <form id="chatMessageForm" class="w-100" enctype="multipart/form-data">
                                <input type="hidden" id="chatId" value="" />
                                <div class="input-group">
                                    <input type="text" id="chatMessageInput" class="form-control" placeholder="Введите сообщение..." autocomplete="off" required>
                                    <button type="button" id="attachFileButton" class="btn btn-outline-secondary" title="Прикрепить файл">
                                        <i class="fas fa-paperclip"></i>
                                    </button>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-paper-plane"></i>
                                    </button>
                                </div>
                                <input type="file" id="fileInput" style="display: none;" accept="image/*" />
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    
    @Html.AntiForgeryToken()
    @if (!isAdmin)
    {
        <script src="~/js/chat-modal.js" asp-append-version="true"></script>
    }

    <script>
        (async function loadInfoPages() {
            try {
                const response = await fetch('/api/pages/menu');
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const pages = await response.json();
                
                function fillMenu(menuId) {
                    const menu = document.getElementById(menuId);
                    if (!menu) return;
                    menu.innerHTML = '';
                    if (!pages.length) {
                        menu.innerHTML = '<li><span class="dropdown-item text-muted">Нет страниц</span></li>';
                        return;
                    }
                    pages.forEach(page => {
                        const li = document.createElement('li');
                        li.innerHTML = `<a class="dropdown-item" href="/page/${page.slug}">${page.title}</a>`;
                        menu.appendChild(li);
                    });
                }
                
                fillMenu('infoPagesMenu');
                fillMenu('infoPagesMenuMobile');
            } catch (err) {
                console.error('Ошибка загрузки страниц:', err);
                document.querySelectorAll('#infoPagesMenu, #infoPagesMenuMobile').forEach(menu => {
                    if (menu) menu.innerHTML = '<li><span class="dropdown-item text-danger">Ошибка загрузки</span></li>';
                });
            }
        })();
    </script>
</body>
</html>